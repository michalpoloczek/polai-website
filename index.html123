      <textarea class="ftxt" id="fM" placeholder="Opisz swoją firmę i czego potrzebujesz..."></textarea>
      <button class="btn-black" style="width:100%;border:none;cursor:pointer" onclick="subForm()">Wyślij — oddzwonimy w 2h</button>
      <div class="fmsg" id="fMsg"></div>
