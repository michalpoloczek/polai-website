<button class="cbb" id="cbb">
  <span class="cbnotif" id="cbnotif" style="display:none">1</span>
  <svg class="cbci" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
  <svg class="cbxv" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
</button>
<div class="cbw" id="cbw">
  <div class="cbh">
    <div class="cbav"><div class="cbav-t">PAI</div></div>
    <div><div class="cbname">PolAI · Asystent</div><div class="cbst">Online — odpowiadamy szybko</div></div>
  </div>
  <div class="cbm" id="cbm"></div>
  <div class="cbqr" id="cbqr"></div>
  <div class="cbir">
    <input class="cbinp" id="cbinp" placeholder="Napisz pytanie...">
    <button class="cbsend" id="cbsend"><svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg></button>
  </div>
  <div class="cbpw">Asystent AI · <strong>PolAI</strong> · polai.tech</div>
</div>

<script>
window.addEventListener('scroll',function(){document.getElementById('nav').classList.toggle('sc',scrollY>50)});
var mobOpen=false;
function tgMob(){mobOpen=!mobOpen;document.getElementById('mob').classList.toggle('on',mobOpen)}
var obs=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting)x.target.classList.add('on')})},{threshold:0.07});
document.querySelectorAll('.fi').forEach(function(el){obs.observe(el)});

function updSlider(sid,vid,fmt){
  document.getElementById(vid).textContent=fmt(parseFloat(document.getElementById(sid).value));
}

function calcROI(){
  var v=parseFloat(document.getElementById('sV').value)||0;
  var c=parseFloat(document.getElementById('sC').value)||0;
  var val=parseFloat(document.getElementById('sVal').value)||0;
  var mult=parseFloat(document.getElementById('cB').value)||2;
  var pkg=parseFloat(document.getElementById('sPkg').value)||899;
  var curL=v*(c/100);
  var newC=Math.min(c*mult,100);
  var newL=v*(newC/100);
  var addL=Math.max(0,Math.round(newL-curL));
  var addR=Math.round(addL*val);
  var profit=addR-pkg;
  var roi=Math.round((addR-pkg)/pkg*100);
  var pb=addR>0?Math.ceil(pkg/addR*30):0;
  document.getElementById('crL').textContent='+'+addL;
  document.getElementById('crR').textContent='+'+addR.toLocaleString('pl-PL')+' zl';
  document.getElementById('crProfit').textContent=(profit>=0?'+':'')+profit.toLocaleString('pl-PL')+' zl';
  document.getElementById('crProfit').style.color=profit>=0?'rgba(255,255,255,.9)':'#F87171';
  document.getElementById('crROI').textContent=(roi>0?'+':'')+roi+'%';
  document.getElementById('crROI').style.color=roi>=0?'rgba(255,255,255,.9)':'#F87171';
  document.getElementById('crPB').textContent=pb>0?pb+' dni':'<1 dzien';
  ['crL','crR','crProfit','crROI','crPB'].forEach(function(id){document.getElementById(id).classList.add('on');});
}

function subForm(){
  var n=document.getElementById('fN').value.trim(),p=document.getElementById('fP').value.trim();
  var msg=document.getElementById('fMsg');
  if(!n||!p){msg.textContent='Proszę podać imię i numer telefonu.';msg.className='fmsg err';return;}
  var btn=document.querySelector('#kontakt .btn-black');btn.textContent='Wysyłanie...';btn.disabled=true;
  fetch('https://formspree.io/f/mpqknnrw',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({imie:n,telefon:p,email:document.getElementById('fE').value,branza:document.getElementById('fB').value,wiadomosc:document.getElementById('fM').value,zrodlo:'PolAI polai.tech'})})
  .then(function(r){if(r.ok){btn.textContent='Wysłano!';msg.textContent='Dziękujemy! Oddzwonimy w ciągu 2 godzin.';msg.className='fmsg ok';}else{btn.textContent='Spróbuj ponownie';btn.disabled=false;msg.textContent='Błąd. Zadzwoń: 574 940 983';msg.className='fmsg err';}})
  .catch(function(){btn.textContent='Spróbuj ponownie';btn.disabled=false;msg.className='fmsg err';msg.textContent='Błąd połączenia.';});
}

var chatOpen=false,fc=0;
var CF={
  start:{msg:'Cześć! Jestem asystentem PolAI.\n\nTworzymy chatboty AI dla lokalnych firm w Polsce.\n\nW czym mogę pomóc?',opts:['Czym jest chatbot AI?','Ile to kosztuje?','Jak szybko wdrożycie?','Dla jakich firm?','Bezpłatna konsultacja']},
  'Czym jest chatbot AI?':{msg:'Chatbot AI to wirtualny asystent na Twojej stronie.\n\nOdpowiada na pytania klientów, zbiera dane kontaktowe i umawia wizyty — automatycznie, 24/7.\n\nPrzykład: klient wchodzi o 22:00, pyta o cenę — chatbot odpowiada i zapisuje numer. Rano dzwonisz z gotowym klientem.',opts:['Ile to kosztuje?','Dla jakich firm?','Bezpłatna konsultacja','Wstecz']},
  'Ile to kosztuje?':{msg:'Cennik PolAI:\n\nStart: 599 zł/mies\nPro: 899 zł/mies\nPremium: 1499 zł/mies\n\nCo ważne:\n— Pierwszy miesiąc BEZPŁATNIE\n— Wdrożenie w 48 godzin\n— Bez długich umów\n— 1 klient = zwrot kosztów',opts:['Co zawiera Pro?','Bezpłatna konsultacja','Wstecz']},
  'Co zawiera Pro?':{msg:'Pakiet Pro (899 zł/mies):\n\nChatbot na stronie 24/7\nPełna baza wiedzy firmy\nZbieranie kontaktów\nPanel recepcji z leadami\nPowiadomienia email\nMiesięczny raport\nPriorytetowe wsparcie\n\nWdrożenie w 48 godzin.',opts:['Bezpłatna konsultacja','Wstecz']},
  'Jak szybko wdrożycie?':{msg:'48 godzin od konsultacji.\n\n1. Konsultacja i zebranie info\n2. Budujemy chatbota\n3. Wysyłamy gotowy skrypt\n4. Wklejasz kod na stronę\n5. Chatbot działa!\n\nZero wiedzy technicznej po Twojej stronie.',opts:['Ile to kosztuje?','Bezpłatna konsultacja','Wstecz']},
  'Dla jakich firm?':{msg:'Pracujemy z lokalnymi firmami:\n\nGabinety stomatologiczne\nKliniki medycyny estetycznej\nSzkoły jazdy\nGabinety kosmetyczne\nRestauracje i kawiarnie\nFirmy usługowe B2B\n\nJeśli masz stronę i klientów — chatbot się opłaca.',opts:['Ile to kosztuje?','Bezpłatna konsultacja','Wstecz']},
  'Bezpłatna konsultacja':{msg:'Bezpłatna konsultacja:\n— 30 minut rozmowy\n— Demo dla Twojej branży\n— Wycena i plan wdrożenia\n— Zero zobowiązań\n\nZostaw dane — oddzwonimy w 2h:',form:true,opts:['Wstecz']},
  'Wstecz':{msg:'W czym jeszcze mogę pomóc?',opts:['Czym jest chatbot AI?','Ile to kosztuje?','Jak szybko wdrożycie?','Dla jakich firm?','Bezpłatna konsultacja']}
};

function gt(){return new Date().toLocaleTimeString('pl-PL',{hour:'2-digit',minute:'2-digit'})}
function sd(){var m=document.getElementById('cbm');m.scrollTop=m.scrollHeight}

function addBot(data){
  var m=document.getElementById('cbm');
  var w=document.createElement('div');w.className='cm b';
  var lbl=document.createElement('div');lbl.className='cmlbl';lbl.textContent='PolAI';w.appendChild(lbl);
  if(data.msg){var b=document.createElement('div');b.className='cmbub';b.textContent=data.msg;w.appendChild(b);}
  if(data.form){
    fc++;var fid='pf'+fc;
    var form=document.createElement('div');form.className='cbform';
    var fl=document.createElement('div');fl.className='cbformlbl';fl.textContent='Zostaw kontakt — oddzwonimy';form.appendChild(fl);
    var i1=document.createElement('input');i1.id=fid+'n';i1.placeholder='Imię i nazwisko';form.appendChild(i1);
    var i2=document.createElement('input');i2.id=fid+'p';i2.placeholder='Numer telefonu';i2.type='tel';form.appendChild(i2);
    var btn=document.createElement('button');btn.textContent='Wyślij — oddzwonimy!';
    (function(f){btn.onclick=function(){subCB(f);};})(fid);
    form.appendChild(btn);w.appendChild(form);
  }
  var t=document.createElement('div');t.className='cmtime';t.textContent=gt();w.appendChild(t);
  m.appendChild(w);sd();
}
function addUser(text){var m=document.getElementById('cbm');var w=document.createElement('div');w.className='cm u';var b=document.createElement('div');b.className='cmbub';b.textContent=text;w.appendChild(b);var t=document.createElement('div');t.className='cmtime';t.textContent=gt();w.appendChild(t);m.appendChild(w);sd();}
function showTyp(){var m=document.getElementById('cbm');var w=document.createElement('div');w.className='cm b';w.id='cbtyp';var tb=document.createElement('div');tb.className='cbtyp';for(var i=0;i<3;i++){var d=document.createElement('div');d.className='ctd';tb.appendChild(d);}w.appendChild(tb);m.appendChild(w);sd();}
function rmTyp(){var e=document.getElementById('cbtyp');if(e)e.remove();}
function setQR(opts){var qr=document.getElementById('cbqr');qr.innerHTML='';if(!opts||!opts.length)return;opts.forEach(function(opt){var b=document.createElement('button');b.className='cbqb';b.textContent=opt;b.onclick=function(){cbHandle(opt);};qr.appendChild(b);});}
function cbHandle(key){addUser(key);setQR(null);showTyp();var data=CF[key]||CF['Wstecz'];setTimeout(function(){rmTyp();addBot(data);setQR(data.opts);},500+Math.floor(Math.random()*300));}
window.subCB=function(fid){
  var n=document.getElementById(fid+'n').value.trim(),p=document.getElementById(fid+'p').value.trim();
  if(!n||p.replace(/[^0-9]/g,'').length<9){alert('Podaj imię i numer.');return;}
  document.getElementById(fid+'n').parentNode.innerHTML='<div style="text-align:center;padding:10px 0"><div style="font-size:16px;margin-bottom:4px">✓</div><div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#0A0A0A;font-weight:600">Dziękujemy!</div><div style="font-size:12px;color:#999;margin-top:3px">Oddzwonimy wkrótce.</div></div>';
  addUser(n+' · '+p);setQR(null);showTyp();
  fetch('https://formspree.io/f/mpqknnrw',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({imie:n,telefon:p,zrodlo:'Chatbot PolAI'})});
  setTimeout(function(){rmTyp();addBot({msg:'Dziękujemy '+n.split(' ')[0]+'!\n\nOddzwonimy w ciągu 2 godzin i pokażemy demo chatbota dla Twojej firmy.',opts:['Czym jest chatbot AI?','Ile to kosztuje?','Dla jakich firm?']});setQR(['Czym jest chatbot AI?','Ile to kosztuje?','Dla jakich firm?']);},900);
};
function cbSend(){var inp=document.getElementById('cbinp');var text=inp.value.trim();if(!text)return;inp.value='';var lv=text.toLowerCase(),key=null;
  if(/koszt|cen|ile/.test(lv))key='Ile to kosztuje?';
  else if(/czym|co to|chatbot/.test(lv))key='Czym jest chatbot AI?';
  else if(/szybko|kiedy|48/.test(lv))key='Jak szybko wdrożycie?';
  else if(/bran|kogo|firm/.test(lv))key='Dla jakich firm?';
  else if(/konsultac|demo|bezplatn/.test(lv))key='Bezpłatna konsultacja';
  addUser(text);setQR(null);showTyp();
  setTimeout(function(){rmTyp();if(key&&CF[key]){addBot(CF[key]);setQR(CF[key].opts);}else{addBot({msg:'Chętnie pomogę! Skorzystaj z przycisków lub zadzwoń: +48 574 940 983',opts:CF.start.opts});setQR(CF.start.opts);}},700);
}
document.getElementById('cbb').addEventListener('click',function(){chatOpen=!chatOpen;var w=document.getElementById('cbw');if(chatOpen){w.style.display='flex';this.classList.add('open');if(!document.getElementById('cbm').children.length){showTyp();setTimeout(function(){rmTyp();addBot(CF.start);setQR(CF.start.opts);},1000);}}else{w.style.display='none';this.classList.remove('open');}document.getElementById('cbnotif').style.display='none';});
document.getElementById('cbsend').addEventListener('click',cbSend);
document.getElementById('cbinp').addEventListener('keydown',function(e){if(e.key==='Enter')cbSend();});
setTimeout(function(){document.getElementById('cbnotif').style.display='flex';},5000);
</script>
</body>
</html>
