    </div>
    <div class="fi">
      <div class="frow">
        <div><label class="flabel">Imię i nazwisko</label><input class="finput" id="fN" placeholder="Jan Kowalski"></div>
        <div><label class="flabel">Telefon</label><input class="finput" id="fP" placeholder="500 000 000" type="tel"></div>
      </div>
      <label class="flabel">Email</label><input class="finput" id="fE" placeholder="jan@firma.pl" type="email">
      <label class="flabel">Branża</label>
      <select class="fsel" id="fB">
        <option value="">Wybierz...</option>
