<section id="kontakt" class="sec bg2">
  <div class="sey fi">Kontakt</div>
  <h2 class="sh fi">Zacznij <em>dziś</em></h2>
  <p class="ssub fi">Bezpłatna konsultacja — demo dopasowane do Twojej branży. Zero zobowiązań.</p>
  <div class="ko-grid">
    <div class="fi">
      <div class="ko-lbl">Telefon</div><div class="ko-val"><a href="tel:574940983">+48 574 940 983</a></div>
      <div class="ko-lbl">Email</div><div class="ko-val"><a href="mailto:kontakt@polai.tech">kontakt@polai.tech</a></div>
      <div class="ko-lbl">Zasięg</div><div class="ko-val">Cała Polska<br>Wszystkie branże</div>
