<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>PolAI – Agencja AI dla lokalnych firm | Opole</title>
<meta name="description" content="PolAI tworzy chatboty AI dla lokalnych firm w Polsce. Asystent AI działa 24/7 – zbiera leady, odpowiada na pytania, umawia wizyty.">
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --w:#FFFFFF;
  --w2:#F7F7F7;
  --w3:#EFEFEF;
  --black:#0A0A0A;
  --black2:#1A1A1A;
  --tx:#0A0A0A;
  --tx2:#555555;
  --tx3:#999999;
  --line:#E0E0E0;
  --line2:#F0F0F0;
  --blue:#2563EB;
  --blue2:#1B4FD8;
  --blue-bg:rgba(37,99,235,.07);
  --blue-line:rgba(37,99,235,.2);
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;font-weight:300;background:var(--w);color:var(--tx);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:999;padding:20px 64px;display:flex;align-items:center;justify-content:space-between;transition:all .4s;background:transparent}
nav.sc{background:rgba(255,255,255,.97);backdrop-filter:blur(20px);padding:14px 64px;border-bottom:1px solid var(--line2);box-shadow:0 1px 16px rgba(0,0,0,.06)}
.logo{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--black);text-decoration:none;font-weight:400;letter-spacing:.03em}
.logo em{font-style:italic}
.nls{display:flex;align-items:center;gap:36px}
.nls a{font-size:11px;font-weight:400;letter-spacing:.13em;text-transform:uppercase;color:var(--tx2);text-decoration:none;transition:color .2s}
.nls a:hover{color:var(--black)}
.ncta{background:var(--black);color:var(--w);padding:11px 28px;font-size:11px;font-weight:400;letter-spacing:.13em;text-transform:uppercase;text-decoration:none;transition:background .3s}
.ncta:hover{background:var(--black)}
.nhm{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer}
.nhm span{width:22px;height:1px;display:block;background:var(--black)}

/* MOB */
.mob{position:fixed;inset:0;background:var(--w);z-index:998;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:26px;transform:translateX(100%);transition:transform .4s cubic-bezier(.77,0,.18,1)}
.mob.on{transform:translateX(0)}
.mob a{font-family:'Libre Baskerville',serif;font-size:32px;color:var(--black);text-decoration:none}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;overflow:hidden}
.hl{display:flex;flex-direction:column;justify-content:center;padding:130px 64px 80px;position:relative}
.hl::after{content:'';position:absolute;right:0;top:0;bottom:0;width:1px;background:var(--line)}
.heyebrow{font-size:10px;letter-spacing:.44em;text-transform:uppercase;color:var(--tx3);margin-bottom:28px;display:flex;align-items:center;gap:14px}
.heyebrow::before{content:'';display:block;width:28px;height:1px;background:var(--black)}
h1{font-family:'Libre Baskerville',serif;font-size:clamp(44px,5.5vw,76px);line-height:1.06;color:var(--black);margin-bottom:24px;font-weight:400}
h1 em{font-style:italic}
.hero-sub{font-size:15px;color:var(--tx2);line-height:1.95;max-width:420px;margin-bottom:44px;font-weight:300}
.hero-btns{display:flex;align-items:center;gap:18px;margin-bottom:64px;flex-wrap:wrap}
.btn-black{background:var(--black);color:var(--w);padding:14px 36px;font-size:11px;font-weight:400;letter-spacing:.13em;text-transform:uppercase;text-decoration:none;transition:background .3s;display:inline-block;border:none;cursor:pointer}
.btn-black:hover{background:var(--black)}
.btn-out{color:var(--black);font-size:11px;font-weight:400;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;display:inline-flex;align-items:center;gap:7px;border:1px solid var(--black);padding:13px 26px;transition:all .3s}
.btn-out:hover{background:var(--black);color:var(--w)}
.hfeats{display:flex;flex-direction:column;gap:10px}
.hf{display:flex;align-items:center;gap:12px;font-size:13px;color:var(--tx2)}
.hf::before{content:'';width:20px;height:1px;background:var(--black);flex-shrink:0}

/* HERO RIGHT */
.hr{background:var(--black);display:flex;align-items:flex-end;position:relative;overflow:hidden}
.hr-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:44px 44px}
.hr-content{position:relative;z-index:2;padding:64px;width:100%}
.hr-big{font-family:'Libre Baskerville',serif;font-size:clamp(80px,11vw,150px);color:rgba(255,255,255,.04);line-height:.9;font-style:normal;user-select:none;margin-bottom:0}
.hr-tagline{font-family:'Libre Baskerville',serif;font-size:28px;color:rgba(255,255,255,.88);font-weight:400;line-height:1.5;margin-bottom:36px;font-style:normal}
.hr-stats{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.06)}
.hstat{padding:20px;background:rgba(255,255,255,.02)}
.hstat-n{font-family:'Libre Baskerville',serif;font-size:38px;color:rgba(255,255,255,.88);line-height:1;font-style:italic}
.hstat-l{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-top:5px;font-family:"Inter",sans-serif}
.hr-bar{position:absolute;top:0;left:0;right:0;background:var(--black);padding:12px;text-align:center;font-size:11px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,.7);font-family:"Inter",sans-serif;-webkit-font-smoothing:antialiased;border-bottom:none}

/* TICKER */
.ticker{border-top:1px solid var(--line);border-bottom:1px solid var(--line);overflow:hidden;background:var(--w2)}
.ticker-inner{display:flex;white-space:nowrap;animation:tick 30s linear infinite}
.ti{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--tx3);padding:12px 36px;display:inline-flex;align-items:center;gap:36px}
.td{width:2px;height:2px;border-radius:50%;background:var(--tx3);display:inline-block}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* SECTIONS */
.sec{padding:96px 64px;background:var(--w)}
.sec.bg2{background:var(--w2)}
.sec.bgdk{background:var(--black)}
.sey{font-size:10px;letter-spacing:.4em;text-transform:uppercase;color:var(--tx3);margin-bottom:13px;display:flex;align-items:center;gap:11px}
.sey::before{content:'';display:block;width:20px;height:1px;background:var(--black)}
.sh{font-family:'Libre Baskerville',serif;font-size:clamp(32px,4vw,52px);color:var(--black);line-height:1.15;margin-bottom:14px;font-weight:400}
.sh em{font-style:normal;font-weight:500}
.sh.w{color:var(--w)}
.ssub{font-size:15px;color:var(--tx2);line-height:1.9;max-width:520px;margin-bottom:52px;font-weight:300}

/* USŁUGI */
.srv-grid{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line)}
.srv{padding:36px 30px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);transition:background .25s;position:relative}
.srv:nth-child(3n){border-right:none}
.srv:nth-child(n+4){border-bottom:none}
.srv:hover{background:var(--w2)}
.srv-n{font-family:'Libre Baskerville',serif;font-size:48px;color:var(--line);position:absolute;top:14px;right:18px;font-style:italic;line-height:1}
.srv-name{font-family:'Libre Baskerville',serif;font-size:20px;color:var(--black);margin-bottom:10px;font-weight:400}
.srv-desc{font-size:13px;color:var(--tx2);line-height:1.75;margin-bottom:14px}
.srv-tags{display:flex;flex-wrap:wrap;gap:5px}
.srv-tag{font-size:10px;padding:3px 9px;background:var(--w2);border:1px solid var(--line);color:var(--tx3);letter-spacing:.05em}

/* KROKI */
.steps{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line);margin-top:52px}
.step{padding:32px 26px;border-right:1px solid var(--line)}
.step:last-child{border-right:none}
.step-n{font-family:'Libre Baskerville',serif;font-size:44px;color:var(--line);font-style:italic;line-height:1;margin-bottom:14px}
.step-title{font-family:'Libre Baskerville',serif;font-size:17px;color:var(--black);margin-bottom:7px;font-weight:400}
.step-desc{font-size:13px;color:var(--tx2);line-height:1.7}

/* KALKULATOR SUWAKOWY */
.calc-wrap{max-width:880px;margin:0 auto}
.calc-panels{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--line)}
.calc-left{padding:44px;border-right:1px solid var(--line)}
.calc-right{background:var(--black);padding:44px;display:flex;flex-direction:column;justify-content:center}
.slider-field{margin-bottom:28px}
.slider-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px}
.slider-label{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--tx3)}
.slider-value{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--black);font-style:italic;line-height:1}
input[type=range]{-webkit-appearance:none;width:100%;height:2px;background:var(--line);outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;background:var(--black);border-radius:50%;cursor:pointer;transition:transform .15s}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.2)}
input[type=range]::-moz-range-thumb{width:16px;height:16px;background:var(--black);border-radius:50%;cursor:pointer;border:none}
.csel-field{margin-bottom:28px}
.csel-label{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--tx3);display:block;margin-bottom:8px}
.csel{width:100%;background:transparent;border:none;border-bottom:1px solid var(--line);padding:8px 0;font-size:14px;font-family:'Inter',sans-serif;color:var(--black);outline:none;appearance:none;cursor:pointer;font-weight:300}
.csel option{background:var(--w)}
.calc-right-title{font-family:'Libre Baskerville',serif;font-size:17px;color:rgba(255,255,255,.4);font-style:italic;margin-bottom:32px}
.calc-right-title.on{color:rgba(255,255,255,.88)}
.cr-rows{display:flex;flex-direction:column;gap:1px}
.cr-row{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);padding:18px 20px;display:flex;align-items:center;justify-content:space-between}
.cr-lbl{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.3)}
.cr-val{font-family:'Libre Baskerville',serif;font-size:30px;color:rgba(255,255,255,.15);font-style:italic;line-height:1;transition:all .35s}
.cr-val.on{color:rgba(255,255,255,.9)}
.calc-cta{margin-top:28px;text-align:center}
.calc-note{font-size:11px;color:rgba(255,255,255,.2);text-align:center;margin-top:10px}

/* REALIZACJE */
.real-grid{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line);margin-top:52px}
.real{padding:36px;border-right:1px solid var(--line);transition:background .25s}
.real:last-child{border-right:none}
.real:hover{background:var(--w2)}
.real-cat{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--tx3);margin-bottom:11px}
.real-name{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--black);margin-bottom:11px;font-weight:400}
.real-desc{font-size:13.5px;color:var(--tx2);line-height:1.8;margin-bottom:16px}
.real-tag{display:inline-flex;align-items:center;gap:7px;font-size:11px;color:var(--tx2);font-weight:400}
.real-tag::before{content:'↗';color:var(--black)}

/* CENNIK */
.pc-grid{display:grid;grid-template-columns:1fr 1fr 1fr;border:1px solid var(--line);margin-top:52px}
.pc{padding:36px 30px;border-right:1px solid var(--line);position:relative}
.pc:last-child{border-right:none}
.pc.feat{background:var(--black)}
.pc-rec{position:absolute;top:0;left:0;right:0;background:var(--black);padding:6px;text-align:center;font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--w)}
.pc.feat .pc-rec{background:var(--w);color:var(--black)}
.pc-name{font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--tx3);margin-bottom:12px;font-family:"Playfair Display",serif;font-style:italic;font-weight:400}
.pc.feat .pc-name{color:rgba(255,255,255,.35);margin-top:20px;font-family:"Playfair Display",serif;font-style:italic}
.pc-price{font-family:'Libre Baskerville',serif;font-size:52px;color:var(--black);line-height:1;font-style:italic;margin-bottom:4px}
.pc.feat .pc-price{color:var(--w)}
.pc-per{font-size:13px;color:var(--tx3);margin-bottom:24px;font-family:"Playfair Display",serif;font-style:italic}
.pc.feat .pc-per{color:rgba(255,255,255,.28);font-family:"Playfair Display",serif;font-style:italic}
.pc-list{list-style:none;margin-bottom:28px}
.pc-list li{font-size:13px;color:var(--tx2);padding:8px 0;border-bottom:1px solid var(--line);display:flex;align-items:flex-start;gap:9px;line-height:1.5}
.pc-list li::before{content:'—';color:var(--tx3);flex-shrink:0;font-size:11px;margin-top:2px}
.pc-list li:last-child{border-bottom:none}
.pc.feat .pc-list li{color:rgba(255,255,255,.5);border-color:rgba(255,255,255,.07)}
.pc-btn{display:block;text-align:center;padding:12px;font-size:13px;font-weight:400;letter-spacing:.08em;text-decoration:none;transition:all .25s;border:1px solid var(--black);color:var(--black);font-family:"Playfair Display",serif;font-style:italic}
.pc-btn:hover{background:var(--black);color:var(--w)}
.pc.feat .pc-btn{border-color:var(--w);color:var(--w)}
.pc.feat .pc-btn:hover{background:var(--w);color:var(--black)}

/* KONTAKT */
.ko-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;margin-top:52px}
.ko-lbl{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--tx3);margin-bottom:5px}
.ko-val{font-size:15px;color:var(--tx2);margin-bottom:22px;line-height:1.6}
.ko-val a{color:var(--tx2);text-decoration:none;transition:color .2s}
.ko-val a:hover{color:var(--black)}
.flabel{display:block;font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--tx3);margin-bottom:6px}
.finput,.fsel,.ftxt{width:100%;background:transparent;border:none;border-bottom:1px solid var(--line);padding:10px 0;color:var(--black);font-family:'Inter',sans-serif;font-size:14px;font-weight:300;outline:none;transition:border-color .2s;margin-bottom:18px;display:block}
.finput:focus,.fsel:focus,.ftxt:focus{border-color:var(--black)}
.finput::placeholder,.ftxt::placeholder{color:var(--tx3)}
.fsel{appearance:none;cursor:pointer}
.fsel option{background:var(--w)}
.ftxt{resize:none;min-height:80px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.fmsg{font-size:13px;margin-top:6px;display:none}
.fmsg.ok{color:var(--black);display:block}
.fmsg.err{color:#DC2626;display:block}

/* FOOTER */
footer{background:var(--black);padding:32px 64px;border-top:1px solid rgba(255,255,255,.06)}
.foi{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px}
.flogo{font-family:'Libre Baskerville',serif;font-size:20px;color:rgba(255,255,255,.6)}
.flogo em{font-style:italic;color:rgba(255,255,255,.88)}
.fls{display:flex;gap:22px}
.fls a{font-size:11px;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.22);text-decoration:none;transition:color .2s}
.fls a:hover{color:rgba(255,255,255,.7)}
.fco{font-size:11px;color:rgba(255,255,255,.15)}

/* CHATBOT */
.cbb{position:fixed;bottom:28px;right:28px;z-index:9999;width:52px;height:52px;background:var(--black);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;box-shadow:0 4px 20px rgba(0,0,0,.15)}
.cbb:hover{transform:scale(1.06)}
.cbb svg{width:22px;height:22px;fill:var(--w)}
.cbxv{display:none}
.cbb.open .cbci{display:none}
.cbb.open .cbxv{display:block}
.cbnotif{position:absolute;top:-3px;right:-3px;width:15px;height:15px;background:var(--black);border:2px solid var(--w);font-size:8px;font-weight:700;color:var(--w);display:flex;align-items:center;justify-content:center;border-radius:50%}
.cbw{position:fixed;bottom:90px;right:28px;width:352px;z-index:9998;display:none;flex-direction:column;background:var(--w);border:1px solid var(--line);box-shadow:0 16px 48px rgba(0,0,0,.12);max-height:540px}
.cbw.on{display:flex}
.cbh{background:var(--black);padding:15px 17px;display:flex;align-items:center;gap:12px}
.cbav{width:38px;height:38px;background:var(--w);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cbav-t{font-family:'Libre Baskerville',serif;font-size:13px;color:var(--black);font-style:italic;font-weight:500}
.cbname{font-family:'Libre Baskerville',serif;font-size:15px;color:var(--w);font-weight:400}
.cbst{font-size:10px;color:rgba(255,255,255,.32);margin-top:2px;display:flex;align-items:center;gap:5px}
.cbst::before{content:'';width:5px;height:5px;background:#22C55E;border-radius:50%;display:inline-block}
.cbm{flex:1;overflow-y:auto;padding:13px;display:flex;flex-direction:column;gap:9px;background:var(--w2);min-height:300px;max-height:360px}
.cbm::-webkit-scrollbar{width:2px}
.cbm::-webkit-scrollbar-thumb{background:var(--line)}
.cm{display:flex;flex-direction:column;max-width:88%}
.cm.b{align-self:flex-start}.cm.u{align-self:flex-end}
.cmlbl{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--tx3);margin-bottom:3px}
.cmbub{padding:10px 13px;font-size:13px;line-height:1.65;white-space:pre-line;font-family:'Inter',sans-serif;font-weight:300}
.cm.b .cmbub{background:var(--w);color:var(--tx);border:1px solid var(--line);box-shadow:0 1px 3px rgba(0,0,0,.05)}
.cm.u .cmbub{background:var(--black);color:var(--w)}
.cmtime{font-size:9px;color:var(--tx3);margin-top:2px}
.cm.u .cmtime{text-align:right}
.cbtyp{background:var(--w);border:1px solid var(--line);padding:12px 13px;display:flex;gap:5px;align-self:flex-start}
.ctd{width:6px;height:6px;border-radius:50%;background:var(--tx3);animation:ctd 1.2s infinite}
.ctd:nth-child(2){animation-delay:.2s}.ctd:nth-child(3){animation-delay:.4s}
@keyframes ctd{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
.cbform{background:var(--w2);border:1px solid var(--line);padding:12px;margin-top:7px;display:flex;flex-direction:column;gap:6px}
.cbformlbl{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--tx3);font-weight:500}
.cbform input{background:var(--w);border:1px solid var(--line);padding:8px 10px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;width:100%;transition:border-color .2s;font-weight:300}
.cbform input:focus{border-color:var(--black)}
.cbform input::placeholder{color:var(--tx3)}
.cbform button{background:var(--black);color:var(--w);border:none;padding:9px;font-size:10px;font-family:'Inter',sans-serif;font-weight:500;letter-spacing:.12em;text-transform:uppercase;cursor:pointer}
.cbqr{display:flex;flex-wrap:wrap;gap:5px;padding:8px 11px;background:var(--w);border-top:1px solid var(--line)}
.cbqb{font-size:12px;padding:5px 12px;border:1px solid var(--line);background:transparent;color:var(--tx2);cursor:pointer;font-family:'Inter',sans-serif;font-weight:400;transition:all .15s}
.cbqb:hover{background:var(--black);color:var(--w);border-color:var(--black)}
.cbir{display:flex;border-top:1px solid var(--line);background:var(--w);align-items:center}
.cbinp{flex:1;background:transparent;border:none;padding:12px 14px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;font-weight:300}
.cbinp::placeholder{color:var(--tx3)}
.cbsend{width:48px;background:var(--black);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;padding:12px;transition:background .2s}
.cbsend:hover{background:var(--black)}
.cbsend svg{width:13px;height:13px;fill:var(--w)}
.cbpw{background:var(--w);border-top:1px solid var(--line);padding:6px;text-align:center;font-size:10px;color:var(--tx3)}
.cbpw strong{color:var(--black);font-weight:500}

/* FADE */
.fi{opacity:0;transform:translateY(16px);transition:opacity .6s ease,transform .6s ease}
.fi.on{opacity:1;transform:translateY(0)}

@media(max-width:960px){
  nav,nav.sc{padding:14px 20px}
  .nls{display:none}.nhm{display:flex}
  .hero{grid-template-columns:1fr}
  .hr{height:56vw;min-height:280px}
  .hl{padding:84px 20px 52px}
  .sec{padding:64px 20px}
  .srv-grid,.pc-grid,.real-grid{grid-template-columns:1fr}
  .srv:nth-child(n){border-right:none}
  .real:nth-child(n){border-right:none;border-bottom:1px solid var(--line)}
  .real:last-child{border-bottom:none}
  .pc:nth-child(n){border-right:none;border-bottom:1px solid var(--line)}
  .pc:last-child{border-bottom:none}
  .steps{grid-template-columns:1fr 1fr}
  .step:nth-child(2n){border-right:none}
  .calc-panels,.ko-grid,.frow{grid-template-columns:1fr}
  .calc-left{border-right:none;border-bottom:1px solid var(--line)}
  .foi{flex-direction:column;text-align:center}
  .cbw{width:calc(100vw - 20px);right:10px}
}

/* O FIRMIE */
/* TEAM */
.team-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--line);margin-top:32px}
.team-member{padding:36px;border-right:1px solid var(--line);transition:background .2s}
.team-member:last-child{border-right:none}
.team-member:hover{background:var(--w2)}
.tm-role{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--tx3);margin-bottom:8px}
.tm-name{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--black);margin-bottom:10px;font-weight:400}
.tm-desc{font-size:13px;color:var(--tx2);line-height:1.75;margin-bottom:16px}
.tm-contact{display:flex;flex-direction:column;gap:4px}
.tm-contact a{font-size:13px;color:var(--tx2);text-decoration:none;transition:color .2s}
.tm-contact a:hover{color:var(--black)}
@media(max-width:960px){.team-grid{grid-template-columns:1fr}.team-member{border-right:none;border-bottom:1px solid var(--line)}.team-member:last-child{border-bottom:none}}

.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;margin-top:52px}
.about-text{font-size:15px;color:var(--tx2);line-height:1.9;margin-bottom:18px;font-weight:300}
.about-text:last-child{margin-bottom:0}
.about-values{display:flex;flex-direction:column;gap:0;border:1px solid var(--line)}
.av-item{padding:24px 28px;border-bottom:1px solid var(--line);display:flex;gap:20px;align-items:flex-start;transition:background .2s}
.av-item:last-child{border-bottom:none}
.av-item:hover{background:var(--w2)}
.av-num{font-family:'Libre Baskerville',serif;font-size:20px;color:var(--line);font-style:italic;flex-shrink:0;line-height:1;padding-top:2px}
.av-title{font-family:'Libre Baskerville',serif;font-size:17px;color:var(--black);margin-bottom:5px;font-weight:400}
.av-desc{font-size:13px;color:var(--tx2);line-height:1.7}
@media(max-width:960px){.about-grid{grid-template-columns:1fr}}
