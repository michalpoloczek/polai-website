<!-- ============== REALIZACJE ============== -->
<section id="realizacje" class="relative py-28 md:py-36" style="border-top: 1px solid hsl(var(--border) / 0.18);">
  <div class="max-w-[var(--max)] mx-auto px-[var(--gutter)]">
    <div class="flex flex-col items-start gap-5 mb-14">
      <span class="liquid-glass rounded-full px-4 py-1.5 text-xs text-white/80">Realizacje</span>
      <h2 class="blur-text font-display uppercase font-semibold tracking-tight text-white" style="font-size: clamp(40px, 6vw, 80px); line-height: 0.92; max-width: 18ch;">
        Konkretne wdrożenia. Konkretne wyniki.
      </h2>
      <p class="fade-up font-body text-base md:text-lg text-white/65 max-w-xl">
        Wybrane projekty zrealizowane przez PolAI. Każde wdrożenie jest unikalne — budujemy od zera pod konkretną firmę.
      </p>
    </div>

    <article class="liquid-glass rounded-3xl overflow-hidden grid md:grid-cols-2 gap-0 fade-up">
      <!-- LEWA: visual / mock -->
      <div class="relative min-h-[360px] md:min-h-[520px] overflow-hidden" style="background: linear-gradient(135deg, hsl(var(--ochre) / 0.22), hsl(var(--terra) / 0.4));">
        <!-- Subtelny grid background -->
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(hsl(var(--cream)) 1px, transparent 1px), linear-gradient(90deg, hsl(var(--cream)) 1px, transparent 1px); background-size: 40px 40px;"></div>

        <!-- Glow -->
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full blur-3xl opacity-50" style="background: hsl(var(--primary));"></div>

        <!-- Content -->
        <div class="relative z-10 h-full p-8 md:p-10 flex flex-col justify-between">
          <!-- Top tag -->
          <div class="flex items-center gap-2">
            <span class="liquid-glass-strong rounded-full px-3 py-1.5 text-[10px] tracking-[0.18em] uppercase text-white/85">Case study · 2025</span>
          </div>

          <!-- Center brand -->
          <div class="flex flex-col items-start gap-3">
            <div class="font-italic text-white/95" style="font-size: clamp(56px, 9vw, 96px); line-height: 0.95; letter-spacing: -0.03em;">estetiq</div>
            <div class="text-sm text-white/70 max-w-[28ch] leading-relaxed">Gabinet stomatologiczny i medycyny estetycznej. Centrum Opola, ul. Kościuszki 16/5.</div>
          </div>

          <!-- Bottom URL -->
          <div class="liquid-glass-strong rounded-2xl p-4 flex items-center justify-between gap-3">
            <div>
              <div class="text-[10px] tracking-[0.18em] uppercase text-white/50 mb-1">Strona klienta</div>
              <div class="font-display text-lg text-white" style="font-weight: 500;">estetiq.opole.pl</div>
            </div>
            <i data-lucide="external-link" class="text-white/60" style="width:18px;height:18px;"></i>
          </div>
        </div>
      </div>

      <!-- PRAWA: opis -->
      <div class="p-8 md:p-12 flex flex-col gap-6">
        <div class="flex items-center gap-3 text-[10px] tracking-[0.18em] uppercase text-white/50">
          <span>Stomatologia + med. estetyczna</span>
          <span class="w-1 h-1 rounded-full bg-white/30"></span>
          <span>Opole</span>
        </div>

        <h3 class="font-display text-3xl md:text-4xl tracking-tight text-white" style="font-weight: 600; line-height: 1.05;">Estetiq · klinika premium</h3>

        <p class="font-body text-white/75 leading-relaxed">
          Pełen pakiet AI dla nowoczesnej kliniki: strona WWW konwertująca pacjentów, chatbot odbierający zapytania o wizyty 24/7, automatyzacja rezerwacji i przypomnień. Zoptymalizowane pod SEO i GEO — pacjenci znajdują klinikę zarówno w Google, jak i w odpowiedziach ChatGPT.
        </p>

        <div class="grid grid-cols-3 gap-3">
