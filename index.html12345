<style>
  :root {
    --ink:    222 42% 6%;
    --cream:  210 25% 94%;
    --ochre:  210 100% 66%;
    --terra:  222 60% 28%;

    --background:        var(--ink);
    --foreground:        var(--cream);
    --primary:           var(--ochre);
    --primary-foreground: var(--ink);
    --secondary:         var(--terra);
    --secondary-foreground: var(--cream);
    --muted-foreground:  40 6% 72%;
    --border:            40 30% 90%;
    --ring:              var(--ochre);
    --radius:            0.75rem;

    --font-display: "Bricolage Grotesque", "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-body:    "Inter", -apple-system, BlinkMacSystemFont, "Helvetica Neue", system-ui, sans-serif;
    --font-italic:  "Instrument Serif", "Georgia", serif;

    --gutter: clamp(20px, 4.2vw, 56px);
    --max:    1440px;
  }

  html, body { background: hsl(var(--background)); color: hsl(var(--foreground)); }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body); font-size: 16px; line-height: 1.55;
    -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  .font-display { font-family: var(--font-display); }
  .font-body    { font-family: var(--font-body); }
  .font-italic  { font-family: var(--font-italic); font-style: italic; }

  /* === LIQUID GLASS === */
  .liquid-glass {
    background: rgba(255, 255, 255, 0.02);
    background-blend-mode: luminosity;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: none;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.10);
    position: relative; overflow: hidden;
  }
  .liquid-glass::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.4px;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.15) 20%,
      rgba(255,255,255,0)    40%, rgba(255,255,255,0)    60%,
      rgba(255,255,255,0.15) 80%, rgba(255,255,255,0.45) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    pointer-events: none;
  }
  .liquid-glass-strong {
    background: rgba(255, 255, 255, 0.03);
    background-blend-mode: luminosity;
    backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
    box-shadow: 4px 4px 20px rgba(0,0,0,0.25), inset 0 1px 1px rgba(255,255,255,0.18);
    position: relative; overflow: hidden;
  }
  .liquid-glass-strong::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.4px;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.20) 20%,
      rgba(255,255,255,0)    40%, rgba(255,255,255,0)    60%,
      rgba(255,255,255,0.20) 80%, rgba(255,255,255,0.55) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    pointer-events: none;
  }

  .gradient-fade-t { background: linear-gradient(to top,    transparent 0%, hsl(var(--background)) 100%); }
  .gradient-fade-b { background: linear-gradient(to bottom, transparent 0%, hsl(var(--background)) 100%); }
  .vignette        { background: radial-gradient(120% 80% at 50% 60%, transparent 40%, rgba(0,0,0,0.65) 100%); }

  /* === ANIMATIONS === */
  @keyframes marquee     { from { transform: translateX(0) }     to { transform: translateX(-50%) } }
  @keyframes marquee-rev { from { transform: translateX(-50%) }  to { transform: translateX(0) } }
  @keyframes fade-up   { from { opacity:0; transform: translate3d(0,24px,0); filter: blur(8px); } to { opacity:1; transform: translate3d(0,0,0); filter: blur(0); } }
  @keyframes pill-in   { from { opacity:0; transform: translate3d(0,8px,0) scale(0.96); }       to { opacity:1; transform: none scale(1); } }
  @keyframes ticker    { from { transform: translateX(0) }       to { transform: translateX(-50%) } }
  @keyframes ctd       { 0%,60%,100% {transform:translateY(0)} 30% {transform:translateY(-5px)} }
  .marquee-row     { animation: marquee 36s linear infinite; }
  .marquee-row-rev { animation: marquee-rev 42s linear infinite; }
  .marquee-pause:hover .marquee-row,
  .marquee-pause:hover .marquee-row-rev { animation-play-state: paused; }

  /* Word-by-word blur-in */
  .blur-text .word {
    display: inline-block; opacity: 0; filter: blur(10px); transform: translateY(24px);
    transition: opacity .7s cubic-bezier(0.22,1,0.36,1),
                filter   .7s cubic-bezier(0.22,1,0.36,1),
                transform .7s cubic-bezier(0.22,1,0.36,1);
    will-change: opacity, filter, transform;
  }
  .blur-text.is-in .word { opacity: 1; filter: blur(0); transform: none; }

  .fade-up {
    opacity: 0; transform: translate3d(0,16px,0); filter: blur(8px);
    transition: opacity .7s cubic-bezier(0.22,1,0.36,1),
                transform .7s cubic-bezier(0.22,1,0.36,1),
                filter .7s cubic-bezier(0.22,1,0.36,1);
  }
  .fade-up.is-in { opacity: 1; transform: none; filter: none; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
    border-radius: 9999px; padding: 0.85rem 1.6rem;
    font-family: var(--font-body); font-size: 0.95rem; font-weight: 500; letter-spacing: -0.01em;
    transition: transform .15s ease, background-color .2s ease, color .2s ease, box-shadow .2s ease;
    cursor: pointer; border: none; text-decoration: none;
  }
  .btn-hero       { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }
  .btn-hero:hover { background: hsl(var(--primary) / 0.9); }
  .btn-glass      { color: hsl(var(--foreground)); }
  .btn-glass:hover{ background: rgba(255,255,255,0.05); }
  .btn-solid      { background: hsl(var(--foreground)); color: hsl(var(--background)); }
  .btn-solid:hover{ background: hsl(var(--foreground) / 0.9); }
  .btn-sm         { padding: 0.5rem 1rem; font-size: 0.85rem; }
  .btn :is(svg)   { width: 16px; height: 16px; }

  .marquee-mask {
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  /* === KALKULATOR ROI === */
  input[type=range].slider {
    -webkit-appearance: none; appearance: none;
    width: 100%; height: 4px; background: rgba(255,255,255,0.1);
    outline: none; cursor: pointer; border-radius: 9999px;
  }
  input[type=range].slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 18px; height: 18px;
    background: hsl(var(--primary));
    border-radius: 50%; cursor: pointer;
    box-shadow: 0 0 0 4px rgba(255,255,255,0.05);
    transition: transform .15s, box-shadow .15s;
  }
  input[type=range].slider::-webkit-slider-thumb:hover { transform: scale(1.15); box-shadow: 0 0 0 8px rgba(255,255,255,0.06); }
  input[type=range].slider::-moz-range-thumb {
    width: 18px; height: 18px; background: hsl(var(--primary));
    border-radius: 50%; cursor: pointer; border: none;
    box-shadow: 0 0 0 4px rgba(255,255,255,0.05);
  }
  select.glass-select {
    width: 100%; background: transparent; color: hsl(var(--foreground));
    border: none; border-bottom: 1px solid rgba(255,255,255,0.18);
    padding: 12px 0; font-family: var(--font-body); font-size: 15px;
    outline: none; appearance: none; cursor: pointer; font-weight: 400;
  }
  select.glass-select:focus { border-color: hsl(var(--primary)); }
  select.glass-select option { background: hsl(var(--ink)); color: hsl(var(--cream)); }

  .calc-result-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 22px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
  }
  .calc-result-lbl { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
  .calc-result-val { font-family: var(--font-italic); font-size: 32px; line-height: 1; color: hsl(var(--primary)); }

  /* === FORMS === */
  input.glass-input, textarea.glass-input {
    width: 100%; background: transparent; color: hsl(var(--foreground));
    border: none; border-bottom: 1px solid rgba(255,255,255,0.18);
    padding: 12px 0; font-family: var(--font-body); font-size: 14.5px; font-weight: 300;
    outline: none; transition: border-color .2s; resize: none;
  }
  input.glass-input::placeholder, textarea.glass-input::placeholder { color: rgba(255,255,255,0.35); }
  input.glass-input:focus, textarea.glass-input:focus { border-color: hsl(var(--primary)); }
  .form-label { display: block; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 8px; }

  /* Accordion */
  details.faq-item { border-bottom: 1px solid hsl(var(--border) / 0.18); }
  details.faq-item summary {
    list-style: none; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.4rem 0;
    font-family: var(--font-display); text-transform: uppercase;
    font-size: 1.1rem; letter-spacing: -0.01em; font-weight: 500;
    color: hsl(var(--foreground)); transition: color .2s ease;
  }
  details.faq-item summary::-webkit-details-marker { display: none; }
  details.faq-item summary .chev { transition: transform .25s ease, color .2s ease; flex-shrink: 0; }
  details.faq-item[open] summary { color: hsl(var(--primary)); }
  details.faq-item[open] summary .chev { transform: rotate(180deg); color: hsl(var(--primary)); }
  details.faq-item .answer {
    font-family: var(--font-body); color: hsl(var(--foreground) / 0.7);
    font-size: 0.95rem; line-height: 1.65; max-width: 60ch; padding-bottom: 1.4rem;
    animation: fade-up .35s cubic-bezier(0.22,1,0.36,1);
  }

  a:focus-visible, button:focus-visible, summary:focus-visible {
    outline: 2px solid hsl(var(--ring)); outline-offset: 2px; border-radius: 6px;
  }

  .stat-sep::after {
    content: ""; position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    width: 1px; height: 48px; background: hsl(var(--border) / 0.3);
  }
  @media (max-width: 767px) { .stat-sep::after { display: none; } }

  /* === MOBILE OPTIMIZATIONS === */
  @media (max-width: 767px) {
    #hero { height: 180vh !important; }
  }

  /* === COOKIE BANNER === */
  .cookie-banner {
    position: fixed; left: 50%; bottom: 24px; transform: translateX(-50%);
    z-index: 9997;
    width: min(720px, calc(100vw - 32px));
    padding: 18px 22px;
    display: none; flex-direction: row; align-items: center; gap: 16px;
    border-radius: 18px;
    color: hsl(var(--foreground));
    animation: pill-in .5s cubic-bezier(0.22,1,0.36,1) both;
  }
  .cookie-banner.on { display: flex; }
  .cookie-banner-text { flex: 1; font-size: 13px; color: rgba(255,255,255,0.78); line-height: 1.55; }
  .cookie-banner-text strong { color: hsl(var(--foreground)); font-weight: 600; }
  .cookie-banner-text a { color: hsl(var(--primary)); text-decoration: underline; text-underline-offset: 2px; }
  .cookie-banner-actions { display: flex; gap: 8px; flex-shrink: 0; }
  .cookie-btn {
    padding: 9px 18px; font-size: 12.5px; font-weight: 500; letter-spacing: -0.01em;
    border-radius: 9999px; border: none; cursor: pointer; transition: opacity .15s, background-color .2s;
    font-family: var(--font-body);
  }
  .cookie-btn-accept { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }
  .cookie-btn-accept:hover { background: hsl(var(--primary) / 0.9); }
  .cookie-btn-reject { background: rgba(255,255,255,0.06); color: hsl(var(--foreground)); }
  .cookie-btn-reject:hover { background: rgba(255,255,255,0.12); }
  @media (max-width: 640px) {
    .cookie-banner { flex-direction: column; align-items: stretch; padding: 16px; bottom: 16px; }
    .cookie-banner-actions { flex-direction: row; justify-content: stretch; }
    .cookie-btn { flex: 1; }
  }

  /* Ticker */
  .ticker-track {
    display: flex; white-space: nowrap;
    animation: ticker 30s linear infinite;
  }
  .ticker-item {
    font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase;
    color: rgba(255,255,255,0.45); padding: 14px 0; display: inline-flex;
    align-items: center; gap: 36px;
  }
  .ticker-dot { width: 3px; height: 3px; border-radius: 50%; background: hsl(var(--primary)); display: inline-block; margin: 0 18px; }

  /* === CHATBOT === */
  .cbb {
    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
    width: 56px; height: 56px;
    background: hsl(var(--primary)); color: hsl(var(--primary-foreground));
    border-radius: 50%; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 0 4px rgba(255,255,255,0.04);
    transition: transform .15s ease;
  }
  .cbb:hover { transform: scale(1.06); }
  .cbb svg { width: 24px; height: 24px; }
  .cbnotif {
    position: absolute; top: -2px; right: -2px;
    width: 18px; height: 18px; background: hsl(var(--terra));
    border: 2px solid hsl(var(--ink));
    color: white; font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; border-radius: 50%;
  }
  .cbb.open .cbci { display: none; }
  .cbb:not(.open) .cbxv { display: none; }

  .cbw {
    position: fixed; bottom: 96px; right: 24px; width: 380px; max-width: calc(100vw - 32px);
    z-index: 9998; display: none; flex-direction: column;
    background: hsl(var(--ink)); color: hsl(var(--cream));
    border-radius: 18px; overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.6);
    max-height: 580px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .cbw.on { display: flex; }
  .cbh {
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(20px);
    padding: 16px 18px; display: flex; align-items: center; gap: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .cbav {
    width: 38px; height: 38px; flex-shrink: 0;
    background: linear-gradient(135deg, hsl(var(--ochre)), hsl(var(--terra)));
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 600; color: white; font-size: 13px;
  }
  .cbname { font-family: var(--font-display); font-size: 15px; color: hsl(var(--foreground)); font-weight: 500; }
  .cbst   { font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 2px; display: flex; align-items: center; gap: 6px; }
  .cbst::before { content: ''; width: 6px; height: 6px; background: #22C55E; border-radius: 50%; display: inline-block; }
  .cbm    { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; min-height: 280px; max-height: 340px; }
  .cbm::-webkit-scrollbar { width: 3px; } .cbm::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
  .cm     { display: flex; flex-direction: column; max-width: 88%; }
  .cm.b   { align-self: flex-start; } .cm.u { align-self: flex-end; }
  .cmlbl  { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
  .cmbub  { padding: 10px 14px; font-size: 13.5px; line-height: 1.6; white-space: pre-line; border-radius: 14px; }
  .cm.b .cmbub { background: rgba(255,255,255,0.04); color: hsl(var(--foreground)); border: 1px solid rgba(255,255,255,0.06); }
  .cm.u .cmbub { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }
  .cmtime { font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 3px; }
  .cm.u .cmtime { text-align: right; }
  .cbtyp  { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); padding: 12px 14px; display: flex; gap: 5px; align-self: flex-start; border-radius: 14px; }
  .ctd    { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.4); animation: ctd 1.2s infinite; }
  .ctd:nth-child(2) { animation-delay: .2s; } .ctd:nth-child(3) { animation-delay: .4s; }
  .cbform { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); padding: 12px; margin-top: 8px; display: flex; flex-direction: column; gap: 8px; border-radius: 12px; }
  .cbformlbl { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); font-weight: 500; }
  .cbform input { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); padding: 9px 11px; font-size: 13px; font-family: var(--font-body); color: hsl(var(--foreground)); outline: none; border-radius: 8px; }
  .cbform input:focus { border-color: hsl(var(--primary)); }
  .cbform input::placeholder { color: rgba(255,255,255,0.35); }
  .cbform button { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); border: none; padding: 10px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; border-radius: 8px; }
  .cbqr   { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px 14px; background: rgba(255,255,255,0.02); border-top: 1px solid rgba(255,255,255,0.06); }
  .cbqb   { font-size: 12px; padding: 6px 12px; border: 1px solid rgba(255,255,255,0.12); background: transparent; color: hsl(var(--foreground)); cursor: pointer; border-radius: 9999px; transition: all .15s; font-family: var(--font-body); }
  .cbqb:hover { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); border-color: hsl(var(--primary)); }
  .cbir   { display: flex; border-top: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02); align-items: center; }
  .cbinp  { flex: 1; background: transparent; border: none; padding: 13px 15px; font-size: 13px; font-family: var(--font-body); color: hsl(var(--foreground)); outline: none; }
  .cbinp::placeholder { color: rgba(255,255,255,0.35); }
  .cbsend { width: 48px; background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding: 13px; }
  .cbsend svg { width: 14px; height: 14px; }
  .cbpw   { background: rgba(0,0,0,0.4); padding: 8px; text-align: center; font-size: 10px; color: rgba(255,255,255,0.35); }
  .cbpw strong { color: hsl(var(--primary)); font-weight: 600; }
</style>
</head>

<body>

<!-- ============== NAVBAR ============== -->
<header id="navbar" class="fixed left-1/2 z-50 transition-all duration-300" style="top:1rem; transform: translateX(-50%); width: min(1240px, calc(100vw - 32px));">
  <div class="liquid-glass rounded-full px-2 py-2 flex items-center justify-between gap-4">
    <a href="#" class="flex items-center gap-2 pl-3">
      <div class="w-7 h-7 rounded-full" style="background: radial-gradient(circle at 30% 30%, hsl(var(--ochre)), hsl(var(--terra)));"></div>
      <span class="font-display text-lg tracking-tight font-semibold">Pol<span class="font-italic" style="font-family: var(--font-italic); font-style: italic; font-weight: 500;">AI</span></span>
    </a>
    <nav class="hidden lg:flex items-center gap-1">
      <a href="#uslugi"     class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Usługi</a>
      <a href="#proces"     class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Proces</a>
      <a href="#kalkulator" class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Kalkulator</a>
      <a href="#cennik"     class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Cennik</a>
      <a href="#realizacje" class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Realizacje</a>
      <a href="#opinie"     class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Opinie</a>
      <a href="#faq"        class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">FAQ</a>
      <a href="#kontakt"    class="px-3 py-2 text-sm text-white/75 hover:text-white transition-colors">Kontakt</a>
    </nav>
    <a href="#kontakt" class="btn btn-hero btn-sm rounded-full mr-1">
      Bezpłatna konsultacja <i data-lucide="arrow-up-right"></i>
    </a>
  </div>
</header>

<main>

<!-- ============== HERO + SCRUB CANVAS ============== -->
<section id="hero" class="relative bg-background" style="height: 280vh;">
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    <canvas id="scrubCanvas" class="absolute inset-0 w-full h-full z-0" aria-hidden="true" style="transform: translateZ(0); will-change: contents;"></canvas>
    <p class="sr-only">Animacja sieci neuronowej symbolizującej sztuczną inteligencję, sterowana scrollem.</p>
    <div class="absolute inset-0 z-[1] vignette"></div>
    <div class="absolute bottom-0 inset-x-0 h-[40vh] z-[2] gradient-fade-b"></div>

    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center px-6">
      <div class="liquid-glass rounded-full px-1 py-1 inline-flex items-center gap-2" style="animation: pill-in .8s .2s both cubic-bezier(0.22,1,0.36,1);">
        <span class="bg-primary text-primary-foreground rounded-full px-3 py-1 text-xs font-semibold" style="background: hsl(var(--primary)); color: hsl(var(--primary-foreground));">Agencja AI</span>
        <span class="pr-3 text-sm text-white/85">Cała Polska · Wdrożenie 48h</span>
      </div>

      <h1 class="blur-text mt-6 font-display uppercase font-semibold tracking-tight text-white max-w-[14ch]"
          style="font-size: clamp(56px, 9vw, 144px); line-height: 0.92; letter-spacing: -0.02em;"
          data-stagger="0.09" data-start="0.15">
        Twoja firma nigdy nie śpi.
      </h1>

      <p class="fade-up mt-7 font-body text-base md:text-lg text-white/70 max-w-xl leading-relaxed" style="transition-delay: .9s;">
        Tworzymy chatboty i automatyzacje dla lokalnych firm. Twój asystent AI odpowiada, zbiera leady i umawia wizyty — 24 godziny na dobę.
      </p>

      <div class="fade-up mt-10 flex items-center gap-3 flex-wrap justify-center" style="transition-delay: 1.05s;">
        <a class="btn btn-hero" href="#kontakt">Bezpłatna konsultacja <i data-lucide="arrow-up-right"></i></a>
        <a class="btn btn-glass liquid-glass-strong" href="#kalkulator"><i data-lucide="calculator"></i> Sprawdź ROI</a>
      </div>

      <!-- HERO STATS BAR -->
      <div class="fade-up mt-14 grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden liquid-glass max-w-3xl w-full" style="transition-delay: 1.2s;">
        <div class="px-6 py-5 bg-black/30">
          <div class="font-italic text-3xl md:text-4xl text-white">24/7</div>
          <div class="text-[10px] tracking-widest uppercase text-white/50 mt-1">Dostępność</div>
        </div>
        <div class="px-6 py-5 bg-black/30">
          <div class="font-italic text-3xl md:text-4xl text-white">48h</div>
          <div class="text-[10px] tracking-widest uppercase text-white/50 mt-1">Wdrożenie</div>
        </div>
        <div class="px-6 py-5 bg-black/30">
          <div class="font-italic text-3xl md:text-4xl text-white">100%</div>
          <div class="text-[10px] tracking-widest uppercase text-white/50 mt-1">Skuteczność</div>
        </div>
        <div class="px-6 py-5 bg-black/30">
          <div class="font-italic text-3xl md:text-4xl text-white">ROI</div>
          <div class="text-[10px] tracking-widest uppercase text-white/50 mt-1">Mierzalny zwrot</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============== TICKER ============== -->
<section class="relative border-y border-white/10 overflow-hidden bg-black/30">
  <div class="ticker-track">
    <span class="ticker-item">Chatboty AI<span class="ticker-dot"></span>Automatyzacje<span class="ticker-dot"></span>Zbieranie leadów<span class="ticker-dot"></span>Obsługa 24/7<span class="ticker-dot"></span>WordPress<span class="ticker-dot"></span>Wdrożenie 48h<span class="ticker-dot"></span>Stomatologia<span class="ticker-dot"></span>Szkoły jazdy<span class="ticker-dot"></span>Gabinety medyczne<span class="ticker-dot"></span></span>
    <span class="ticker-item">Chatboty AI<span class="ticker-dot"></span>Automatyzacje<span class="ticker-dot"></span>Zbieranie leadów<span class="ticker-dot"></span>Obsługa 24/7<span class="ticker-dot"></span>WordPress<span class="ticker-dot"></span>Wdrożenie 48h<span class="ticker-dot"></span>Stomatologia<span class="ticker-dot"></span>Szkoły jazdy<span class="ticker-dot"></span>Gabinety medyczne<span class="ticker-dot"></span></span>
  </div>
</section>

<!-- ============== USŁUGI BENTO ============== -->
<section id="uslugi" class="relative py-28 md:py-36">
  <div class="max-w-[var(--max)] mx-auto px-[var(--gutter)]">
    <div class="flex flex-col items-start gap-5 mb-14">
      <span class="liquid-glass rounded-full px-4 py-1.5 text-xs text-white/80">Co robimy</span>
      <h2 class="blur-text font-display uppercase font-semibold tracking-tight text-white"
          style="font-size: clamp(40px, 6vw, 88px); line-height: 0.92; letter-spacing: -0.02em; max-width: 18ch;">
        Cały arsenał AI dla twojej firmy.
      </h2>
      <p class="fade-up font-body text-base md:text-lg text-white/65 max-w-2xl">
        Dziesięć usług które realnie zmieniają jak działa firma — od pierwszego kontaktu z klientem na stronie, przez głos w słuchawce, po reklamy które same się optymalizują.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">

      <!-- 01 - Asystent AI 24/7 (TALL flagship) -->
      <div class="md:row-span-2 md:col-span-1 liquid-glass rounded-2xl p-8 relative overflow-hidden group fade-up" style="min-height: 520px;">
        <div class="flex items-center justify-between mb-6">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="message-square" class="text-white"></i></div>
          <span class="font-italic text-3xl text-white/15">01</span>
        </div>
        <h3 class="font-display uppercase text-3xl md:text-4xl leading-[0.95] tracking-tight mb-4 text-white" style="max-width: 14ch;">Asystent AI 24/7</h3>
        <p class="font-body text-sm text-white/65 max-w-[34ch] leading-relaxed mb-6">
          Chatbot który zna twoją firmę lepiej niż nowy pracownik. Odpowiada na pytania, zbiera kontakty i umawia wizyty — o każdej porze. Po polsku, w tonie twojej marki.
        </p>
        <ul class="space-y-3 text-sm text-white/75 mb-6">
          <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5" style="color: hsl(var(--primary));"></i> Pełna wiedza o ofercie, cenach, FAQ</li>
          <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5" style="color: hsl(var(--primary));"></i> Zbiera kontakty, umawia wizyty</li>
          <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5" style="color: hsl(var(--primary));"></i> Pracuje w niedzielę, w święto, w nocy</li>
          <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5" style="color: hsl(var(--primary));"></i> WordPress, Wix, dowolna strona</li>
          <li class="flex items-start gap-2"><i data-lucide="check" class="mt-0.5" style="color: hsl(var(--primary));"></i> Integracja z Booksy / Google Calendar</li>
        </ul>
        <div class="flex flex-wrap gap-2">
          <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">WordPress</span>
          <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">24/7</span>
          <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Leady</span>
          <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Booksy</span>
        </div>
      </div>

      <!-- 02 - Voice AI -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 240px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="phone-call" class="text-white"></i></div>
          <span class="text-[10px] font-bold tracking-[0.16em] uppercase px-2 py-1 rounded-full" style="background: hsl(var(--primary) / 0.2); color: hsl(var(--primary));">Nowość</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">Voice AI · Asystent głosowy</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Odbiera telefony, brzmi jak człowiek. Umawia wizyty, odpowiada na pytania, zbiera dane. Twoja recepcja nigdy nie odkłada słuchawki.</p>
      </div>

      <!-- 03 - Automatyzacje -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 240px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="zap" class="text-white"></i></div>
          <span class="font-italic text-2xl text-white/15">03</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">Automatyzacje procesów</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Potwierdzenia wizyt, faktury, odpowiedzi na maile, synchronizacja CRM. Workflow który zwalnia ludzi z powtarzalnej pracy. Make, n8n, Zapier.</p>
      </div>

      <!-- 04 - Reklamy Meta + Google z AI (WIDE row 2) -->
      <div class="md:col-span-2 liquid-glass rounded-2xl p-7 relative group fade-up overflow-hidden" style="min-height: 240px;">
        <div class="flex items-start gap-6">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center flex-shrink-0"><i data-lucide="megaphone" class="text-white"></i></div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-display uppercase text-2xl md:text-3xl leading-[0.95] tracking-tight text-white">Reklamy Meta + Google z AI</h3>
              <span class="font-italic text-2xl text-white/15">04</span>
            </div>
            <p class="font-body text-sm text-white/65 leading-relaxed max-w-[60ch] mb-4">Kampanie Facebook, Instagram, Google Ads optymalizowane przez AI. Targetowanie pod twojego klienta lokalnie, copywriting w polskim, kreacje, raportowanie. Średnio 3× więcej leadów przy tym samym budżecie.</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Meta Ads</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Google Ads</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">A/B testy</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Pixel + GA4</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 05 - Premium strony -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 240px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="layout" class="text-white"></i></div>
          <span class="font-italic text-2xl text-white/15">05</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">Premium strony i landingi</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Strony które konwertują, nie tylko ładnie wyglądają. Z wbudowanym chatbotem. Zwykle 3-4× wyższa konwersja niż szablony.</p>
      </div>

      <!-- 06 - Panel dowodzenia leadami -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 240px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="layout-dashboard" class="text-white"></i></div>
          <span class="font-italic text-2xl text-white/15">06</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">Panel dowodzenia leadami</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Dashboard z leadami z chatbota i reklam. Rano otwierasz, masz gotową listę do oddzwonienia. Raporty, alerty, historia konwersacji.</p>
      </div>

      <!-- 07 - SEO + GEO -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 240px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="globe" class="text-white"></i></div>
          <span class="text-[10px] font-bold tracking-[0.16em] uppercase px-2 py-1 rounded-full" style="background: hsl(var(--primary) / 0.2); color: hsl(var(--primary));">Hot</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">SEO + GEO · widoczność w AI</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Pojawiasz się w odpowiedziach ChatGPT, Gemini, Perplexity. Google to nie wszystko — klienci coraz częściej pytają AI. Bądź tam.</p>
      </div>

      <!-- 08 - Cold outreach (WIDE row 4) -->
      <div class="md:col-span-2 liquid-glass rounded-2xl p-7 relative group fade-up" style="min-height: 220px;">
        <div class="flex items-start gap-6">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center flex-shrink-0"><i data-lucide="send" class="text-white"></i></div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-display uppercase text-2xl md:text-3xl leading-[0.95] tracking-tight text-white">Cold outreach z AI</h3>
              <span class="font-italic text-2xl text-white/15">08</span>
            </div>
            <p class="font-body text-sm text-white/65 leading-relaxed max-w-[60ch] mb-4">Personalizowane skrypty telefoniczne, maile sprzedażowe, wiadomości LinkedIn. Sprawdzone na ponad 2000 leadach. Każda wiadomość brzmi jak napisana przez człowieka — bo nim była, tylko z asystą AI.</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Cold email</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">LinkedIn</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Skrypty cold call</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/75">Follow-up</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 09 - Audyt AI + roadmapa -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 220px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="map" class="text-white"></i></div>
          <span class="font-italic text-2xl text-white/15">09</span>
        </div>
        <h3 class="font-display uppercase text-2xl leading-[0.95] tracking-tight mb-2 text-white">Audyt AI + roadmapa</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Sprawdzamy gdzie w twojej firmie AI zadziała najszybciej. Konkretny dokument: co, ile kosztuje, kiedy się zwraca.</p>
      </div>

      <!-- 10 - Produkty Cyfrowe AI (WIDE — NEW flagship) -->
      <div class="md:col-span-2 liquid-glass rounded-2xl p-8 relative group fade-up overflow-hidden" style="min-height: 260px; background: linear-gradient(135deg, hsl(var(--primary) / 0.10), rgba(255,255,255,0.02));">
        <div class="flex items-start gap-6">
          <div class="liquid-glass-strong rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0"><i data-lucide="cpu" class="text-white"></i></div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
              <h3 class="font-display text-2xl md:text-3xl leading-[1.05] tracking-tight text-white" style="font-weight: 600;">Produkty Cyfrowe AI</h3>
              <span class="text-[10px] font-bold tracking-[0.18em] uppercase px-3 py-1.5 rounded-full" style="background: hsl(var(--primary)); color: hsl(var(--primary-foreground));">Nasza domena</span>
            </div>
            <p class="font-body text-[15px] text-white/75 leading-relaxed max-w-[60ch] mb-5">
              Aplikacje, dashboardy, asystenci, narzędzia wewnętrzne — w pełni dopasowane pod twoją firmę. Od pomysłu do działającego produktu w 4–8 tygodni. Twoja firma dostaje technologię, której nie ma konkurencja.
            </p>
            <div class="flex flex-wrap gap-2 mb-5">
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/80">Aplikacje webowe</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/80">Dashboardy AI</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/80">Asystenci wewnętrzni</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/80">MVP w 4 tygodnie</span>
              <span class="text-[11px] px-2.5 py-1 rounded-full liquid-glass-strong text-white/80">Pełna własność kodu</span>
            </div>
            <a href="#kontakt" class="btn btn-glass liquid-glass-strong">Porozmawiajmy o twoim produkcie <i data-lucide="arrow-right"></i></a>
          </div>
        </div>
      </div>

      <!-- 11 - Integracje + Wsparcie 24/7 (small) -->
      <div class="liquid-glass rounded-2xl p-6 relative group fade-up" style="min-height: 260px;">
        <div class="flex items-center justify-between mb-5">
          <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="git-branch" class="text-white"></i></div>
          <span class="font-italic text-2xl text-white/15">11</span>
        </div>
        <h3 class="font-display text-2xl leading-[1.05] tracking-tight mb-2 text-white" style="font-weight: 600;">Integracje + Wsparcie 24/7</h3>
        <p class="font-body text-sm text-white/65 leading-relaxed">Booksy, Google Calendar, Salesforce, HubSpot, własne API. Plus SLA 24h, aktualizacje treści, zmiany w locie.</p>
      </div>

    </div>
  </div>
</section>

<!-- ============== POURQUOI / DLACZEGO MY ============== -->
<section id="dlaczego" class="relative py-28 md:py-36" style="border-top: 1px solid hsl(var(--border) / 0.18);">
  <div class="max-w-[var(--max)] mx-auto px-[var(--gutter)] text-center">
    <span class="liquid-glass rounded-full px-4 py-1.5 text-xs text-white/80 inline-block">Dlaczego PolAI</span>
    <h2 class="blur-text mt-6 font-display uppercase font-semibold tracking-tight text-white mx-auto" style="font-size: clamp(40px, 6vw, 80px); line-height: 0.92; max-width: 18ch;">
      Robimy to na poważnie.
    </h2>
    <p class="fade-up mt-6 font-body text-base md:text-lg text-white/65 max-w-xl mx-auto">
      Cztery zasady które robią różnicę pomiędzy „spróbujemy AI" a „AI faktycznie nam działa".
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mt-16 max-w-[var(--max)] mx-auto px-[var(--gutter)]">

    <div class="liquid-glass rounded-2xl p-7 flex flex-col gap-5 fade-up" style="min-height: 260px;">
      <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="award" class="text-white"></i></div>
      <h3 class="font-display uppercase text-xl tracking-tight text-white">Zero kompromisów</h3>
      <p class="font-body text-sm text-white/65 leading-relaxed">Nie sprzedajemy szablonów. Każdy chatbot jest budowany od zera — z pełną wiedzą o firmie, jej ofercie i klientach.</p>
      <div class="mt-auto h-px w-10" style="background: linear-gradient(to right, hsl(var(--primary)), transparent);"></div>
    </div>

    <div class="liquid-glass rounded-2xl p-7 flex flex-col gap-5 fade-up" style="min-height: 260px;">
      <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="zap" class="text-white"></i></div>
      <h3 class="font-display uppercase text-xl tracking-tight text-white">Wdrożenie w 48h</h3>
      <p class="font-body text-sm text-white/65 leading-relaxed">Od pierwszej rozmowy do działającego chatbota — 48 godzin. Bez tygodni czekania, bez skomplikowanych integracji.</p>
      <div class="mt-auto h-px w-10" style="background: linear-gradient(to right, hsl(var(--primary)), transparent);"></div>
    </div>

    <div class="liquid-glass rounded-2xl p-7 flex flex-col gap-5 fade-up" style="min-height: 260px;">
      <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="target" class="text-white"></i></div>
      <h3 class="font-display uppercase text-xl tracking-tight text-white">Wyniki, nie obietnice</h3>
      <p class="font-body text-sm text-white/65 leading-relaxed">Mierzymy leady, konwersję i zwrot z inwestycji. Chatbot ma przynosić realne pieniądze — i tak właśnie działa.</p>
      <div class="mt-auto h-px w-10" style="background: linear-gradient(to right, hsl(var(--primary)), transparent);"></div>
    </div>

    <div class="liquid-glass rounded-2xl p-7 flex flex-col gap-5 fade-up" style="min-height: 260px;">
      <div class="liquid-glass-strong rounded-full w-11 h-11 flex items-center justify-center"><i data-lucide="map-pin" class="text-white"></i></div>
      <h3 class="font-display uppercase text-xl tracking-tight text-white">Cała Polska</h3>
      <p class="font-body text-sm text-white/65 leading-relaxed">Działamy zdalnie w całym kraju. Stomatologia, szkoły jazdy, kliniki, restauracje, kancelarie — każda branża, każde miasto.</p>
      <div class="mt-auto h-px w-10" style="background: linear-gradient(to right, hsl(var(--primary)), transparent);"></div>
    </div>

  </div>
</section>

