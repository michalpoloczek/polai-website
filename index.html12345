<script>
/* =================== BLUR-TEXT WORD STAGGER =================== */
document.querySelectorAll('.blur-text').forEach(el => {
  const stagger = parseFloat(el.dataset.stagger || '0.07');
  const start   = parseFloat(el.dataset.start   || '0');
  const text    = el.textContent.trim();
  el.innerHTML  = '';
  const words = text.split(' ');
  words.forEach((w, i) => {
    const span = document.createElement('span');
    span.className = 'word';
    span.style.transitionDelay = (start + i * stagger).toFixed(2) + 's';
    span.textContent = w;
    el.appendChild(span);
    if (i < words.length - 1) {
      const sp = document.createElement('span');
      sp.textContent = ' ';
      sp.style.display = 'inline-block';
      sp.style.width = '0.28em';
      el.appendChild(sp);
    }
  });
});

const io = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); } });
}, { threshold: 0.18 });
document.querySelectorAll('.blur-text, .fade-up').forEach(el => io.observe(el));

/* =================== TESTIMONIALS =================== */
const testimonials = [
  { quote: "Chatbot zaczął zbierać leady drugiego dnia po wdrożeniu. Pierwszy klient po tygodniu, koszt całego miesiąca zwrócił się od razu.", name: "Właściciel kliniki stomatologicznej", role: "Klient PolAI" },
  { quote: "Wdrożenie w 48h to nie marketing — faktycznie tyle to trwało. W poniedziałek rozmowa, w środę chatbot na stronie i działa.", name: "Manager kliniki medycyny estetycznej", role: "Klient PolAI" },
  { quote: "Panel recepcji pokazuje wszystkie pytania klientów. Wiem co ich nurtuje i mogę dopasować ofertę. Plus 40% leadów z chatbota.", name: "Restaurator", role: "Klient PolAI" },
  { quote: "Wreszcie ktoś tłumaczy AI po ludzku. Bez buzzwordów, konkretne liczby, konkretne efekty. Polecam każdej firmie usługowej.", name: "Partner kancelarii prawnej", role: "Klient PolAI" },
  { quote: "Asystent AI obsługuje 70% zapytań sam. Recepcjonistka ma czas na klientów w gabinecie zamiast odbierać pytania o godziny.", name: "Lekarz medycyny estetycznej", role: "Klient PolAI" },
  { quote: "Chatbot odpowiada na FAQ o 23:00 w niedzielę. Rano mam listę telefonów do oddzwonienia. Tak po prostu.", name: "Właściciel szkoły jazdy", role: "Klient PolAI" },
  { quote: "ROI 380% w pierwszym kwartale. Płacę 899 zł, a chatbot przynosi 3-4 nowych klientów miesięcznie po średnio 1200 zł każdy.", name: "Fizjoterapeuta · gabinet prywatny", role: "Klient PolAI" },
  { quote: "Profesjonalizm na poziomie zachodnich agencji, ceny polskie. I do tego po polsku — bez akcentu, bez 'let's circle back'.", name: "Właściciel salonu kosmetycznego", role: "Klient PolAI" },
];
function makeCard(t) {
  return `
  <article class="liquid-glass rounded-2xl p-7 shrink-0 flex flex-col gap-5" style="width: 380px;">
    <i data-lucide="quote" style="width:20px; height:20px; color: hsl(var(--primary)); opacity: 0.7;"></i>
    <p class="font-body text-white/85 italic leading-relaxed text-[15px]">„${t.quote}"</p>
    <div class="mt-auto flex items-center gap-3">
      <div class="w-9 h-9 rounded-full" style="background: linear-gradient(135deg, hsl(var(--ochre) / 0.7), hsl(var(--terra) / 0.7));"></div>
      <div class="flex flex-col">
        <span class="font-body font-medium text-sm text-white">${t.name}</span>
        <span class="font-body text-xs text-white/55 uppercase tracking-wider">${t.role}</span>
      </div>
    </div>
  </article>`;
}
document.getElementById('row1').innerHTML = [...testimonials, ...testimonials].map(makeCard).join('');
const r2 = [...testimonials.slice(4), ...testimonials.slice(0,4)];
document.getElementById('row2').innerHTML = [...r2, ...r2].map(makeCard).join('');

