};
const gt = () => new Date().toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
const sd = () => { const m = document.getElementById('cbm'); m.scrollTop = m.scrollHeight; };
function addBot(data) {
  const m = document.getElementById('cbm');
  const w = document.createElement('div'); w.className = 'cm b';
  const lbl = document.createElement('div'); lbl.className = 'cmlbl'; lbl.textContent = 'PolAI'; w.appendChild(lbl);
  if (data.msg) { const b = document.createElement('div'); b.className = 'cmbub'; b.textContent = data.msg; w.appendChild(b); }
  if (data.form) {
    fc++; const fid = 'pf' + fc;
    const form = document.createElement('div'); form.className = 'cbform';
    const fl = document.createElement('div'); fl.className = 'cbformlbl'; fl.textContent = 'Zostaw kontakt — oddzwonimy'; form.appendChild(fl);
    const i1 = document.createElement('input'); i1.id = fid + 'n'; i1.placeholder = 'Imię i nazwisko'; form.appendChild(i1);
    const i2 = document.createElement('input'); i2.id = fid + 'p'; i2.placeholder = 'Numer telefonu'; i2.type = 'tel'; form.appendChild(i2);
    const btn = document.createElement('button'); btn.textContent = 'Wyślij — oddzwonimy!';
    btn.onclick = () => subCB(fid);
    form.appendChild(btn); w.appendChild(form);
  }
  const t = document.createElement('div'); t.className = 'cmtime'; t.textContent = gt(); w.appendChild(t);
  m.appendChild(w); sd();
}
function addUser(text) {
  const m = document.getElementById('cbm');
  const w = document.createElement('div'); w.className = 'cm u';
  const b = document.createElement('div'); b.className = 'cmbub'; b.textContent = text; w.appendChild(b);
  const t = document.createElement('div'); t.className = 'cmtime'; t.textContent = gt(); w.appendChild(t);
  m.appendChild(w); sd();
}
function showTyp() {
  const m = document.getElementById('cbm');
  const w = document.createElement('div'); w.className = 'cm b'; w.id = 'cbtyp';
  const tb = document.createElement('div'); tb.className = 'cbtyp';
  for (let i = 0; i < 3; i++) { const d = document.createElement('div'); d.className = 'ctd'; tb.appendChild(d); }
  w.appendChild(tb); m.appendChild(w); sd();
}
function rmTyp() { const e = document.getElementById('cbtyp'); if (e) e.remove(); }
function setQR(opts) {
  const qr = document.getElementById('cbqr'); qr.innerHTML = '';
  if (!opts || !opts.length) return;
  opts.forEach(opt => {
    const b = document.createElement('button'); b.className = 'cbqb'; b.textContent = opt;
    b.onclick = () => cbHandle(opt); qr.appendChild(b);
  });
}
function cbHandle(key) {
  addUser(key); setQR(null); showTyp();
  const data = CF[key] || CF['Wstecz'];
  setTimeout(() => { rmTyp(); addBot(data); setQR(data.opts); }, 500 + Math.floor(Math.random() * 300));
}
function subCB(fid) {
  const n = document.getElementById(fid + 'n').value.trim();
  const p = document.getElementById(fid + 'p').value.trim();
  if (!n || p.replace(/[^0-9]/g, '').length < 9) { alert('Podaj imię i numer telefonu (min. 9 cyfr).'); return; }
  document.getElementById(fid + 'n').parentNode.innerHTML =
    '<div style="text-align:center;padding:12px 0"><div style="font-size:18px;color:hsl(var(--primary));margin-bottom:6px">✓</div><div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:hsl(var(--primary));font-weight:600">Dziękujemy!</div><div style="font-size:12px;color:rgba(255,255,255,.55);margin-top:4px">Oddzwonimy wkrótce.</div></div>';
  addUser(n + ' · ' + p); setQR(null); showTyp();
  fetch('https://formspree.io/f/mpqknnrw', {
    method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ imie: n, telefon: p, zrodlo: 'Chatbot PolAI' })
  });
  setTimeout(() => {
    rmTyp();
    addBot({ msg: 'Dziękujemy ' + n.split(' ')[0] + '!\n\nOddzwonimy w ciągu 2 godzin i pokażemy demo chatbota dla twojej firmy.',
             opts: ['Czym jest chatbot AI?','Ile to kosztuje?','Dla jakich firm?'] });
    setQR(['Czym jest chatbot AI?','Ile to kosztuje?','Dla jakich firm?']);
  }, 900);
}
window.subCB = subCB;
function cbSend() {
  const inp = document.getElementById('cbinp');
  const text = inp.value.trim(); if (!text) return;
  inp.value = '';
  const lv = text.toLowerCase(); let key = null;
  if (/koszt|cen|ile|płać|placic/.test(lv))                      key = 'Ile to kosztuje?';
  else if (/czym|co to|chatbot|asystent/.test(lv))               key = 'Czym jest chatbot AI?';
  else if (/szybko|kiedy|48|wdroż|wdroz/.test(lv))               key = 'Jak szybko wdrożycie?';
  else if (/bran|kogo|dla kogo|firm|stomato|szkoł|kancel/.test(lv)) key = 'Dla jakich firm?';
  else if (/konsultac|demo|bezpłat|bezplat|kontakt|oddzwoń/.test(lv)) key = 'Bezpłatna konsultacja';
  addUser(text); setQR(null); showTyp();
  setTimeout(() => {
    rmTyp();
    if (key && CF[key]) { addBot(CF[key]); setQR(CF[key].opts); }
    else { addBot({ msg: 'Chętnie pomogę! Skorzystaj z przycisków lub zadzwoń: +48 795 338 269', opts: CF.start.opts }); setQR(CF.start.opts); }
  }, 700);
}
document.getElementById('cbb').addEventListener('click', function () {
  chatOpen = !chatOpen;
  const w = document.getElementById('cbw');
  if (chatOpen) {
    w.classList.add('on'); this.classList.add('open');
    if (!document.getElementById('cbm').children.length) {
      showTyp();
      setTimeout(() => { rmTyp(); addBot(CF.start); setQR(CF.start.opts); }, 1000);
    }
  } else {
    w.classList.remove('on'); this.classList.remove('open');
  }
  document.getElementById('cbnotif').style.display = 'none';
});
document.getElementById('cbsend').addEventListener('click', cbSend);
document.getElementById('cbinp').addEventListener('keydown', e => { if (e.key === 'Enter') cbSend(); });
setTimeout(() => { document.getElementById('cbnotif').style.display = 'flex'; }, 5000);

/* =================== COOKIE CONSENT + GA4 (READY) =================== */
(() => {
  const COOKIE_KEY = 'polai_cookie_consent';
  // TODO: po założeniu GA4 wstaw tu Measurement ID (format 'G-XXXXXXX'). Pusty string = GA4 nieaktywny.
  const GA4_ID = '';

  const banner   = document.getElementById('cookieBanner');
  const btnAcc   = document.getElementById('cookieAccept');
  const btnRej   = document.getElementById('cookieReject');
  const consent  = (() => { try { return localStorage.getItem(COOKIE_KEY); } catch (e) { return null; } })();

  function loadGA() {
    if (!GA4_ID || window.__ga_loaded) return;
    window.__ga_loaded = true;
    const s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () { window.dataLayer.push(arguments); };
    window.gtag('js', new Date());
    window.gtag('config', GA4_ID, { anonymize_ip: true });
  }

  function hide() { banner.classList.remove('on'); banner.style.display = 'none'; }

  if (consent === 'accepted') {
    loadGA();
  } else if (consent === 'rejected') {
    /* nic — banner ukryty */
  } else {
    setTimeout(() => banner.classList.add('on'), 1500);
  }

  btnAcc.addEventListener('click', () => {
    try { localStorage.setItem(COOKIE_KEY, 'accepted'); } catch (e) {}
    hide(); loadGA();
  });
  btnRej.addEventListener('click', () => {
    try { localStorage.setItem(COOKIE_KEY, 'rejected'); } catch (e) {}
    hide();
  });
})();

/* =================== LUCIDE ICONS (final) =================== */
if (window.lucide) lucide.createIcons();
</script>
</body>
</html>
