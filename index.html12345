/* =================== CTA AURORA BACKDROP =================== */
function makeAuroraBackdrop(target, hueRange) {
  const isMobileBg = window.innerWidth < 768 || /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
  const c = document.createElement('canvas');
  c.style.cssText = 'width:100%;height:100%;display:block;';
  target.appendChild(c);
  const cx = c.getContext('2d');
  const dpr = Math.min(window.devicePixelRatio || 1, isMobileBg ? 1 : 2);
  const resize = () => { c.width = target.offsetWidth * dpr; c.height = target.offsetHeight * dpr; };
  resize();
  if (!isMobileBg) window.addEventListener('resize', resize);
  let t = 0;
  const blobs = Array.from({length: isMobileBg ? 3 : 5}, () => ({
    x0: Math.random(), y0: Math.random(),
    speed: 0.3 + Math.random() * 0.5,
    phase: Math.random() * Math.PI * 2,
    hue:   hueRange[0] + Math.random() * (hueRange[1] - hueRange[0]),
    size:  0.4 + Math.random() * 0.5,
  }));
  function drawFrame() {
    const W = c.width, H = c.height;
    cx.fillStyle = 'hsl(222, 42%, 5%)';
    cx.fillRect(0, 0, W, H);
    cx.globalCompositeOperation = 'lighter';
    for (const b of blobs) {
      const x = (b.x0 + Math.cos(t * b.speed + b.phase) * 0.18) * W;
      const y = (b.y0 + Math.sin(t * b.speed + b.phase) * 0.2)  * H;
      const r = b.size * Math.max(W, H) * 0.55;
      const g = cx.createRadialGradient(x, y, 0, x, y, r);
      g.addColorStop(0, `hsla(${b.hue}, 70%, 60%, 0.55)`);
      g.addColorStop(1, `hsla(${b.hue}, 70%, 30%, 0)`);
      cx.fillStyle = g;
      cx.beginPath(); cx.arc(x, y, r, 0, Math.PI * 2); cx.fill();
    }
    cx.globalCompositeOperation = 'source-over';
  }
  if (isMobileBg) {
    /* Mobile: jeden statyczny render, bez rAF */
    drawFrame();
  } else {
    function loop() { t += 0.004; drawFrame(); requestAnimationFrame(loop); }
    loop();
  }
}
makeAuroraBackdrop(document.getElementById('ctaBackdrop'), [200, 235]);

/* =================== SCRUB CANVAS =================== */
(() => {
  const canvas = document.getElementById('scrubCanvas');
  const ctx = canvas.getContext('2d', { alpha: true });
  const heroSection = document.getElementById('hero');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const N = window.innerWidth < 768 ? 60 : 140;
  const rand = (seed) => { let x = Math.sin(seed * 9999) * 43758.5453; return x - Math.floor(x); };
  const particles = Array.from({length: N}, (_, i) => ({
    seed: i,
    angle0: rand(i * 1.7) * Math.PI * 2,
    radius0: 0.15 + rand(i * 2.3) * 0.85,
    speed:   0.4 + rand(i * 3.1) * 1.2,
    phase:   rand(i * 4.5) * Math.PI * 2,
    size:    1.2 + rand(i * 5.7) * 2.4,
  }));

  const isMobile = window.innerWidth < 768 || /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
  let dpr = Math.min(window.devicePixelRatio || 1, isMobile ? 1 : 2);
  const resize = () => {
    dpr = Math.min(window.devicePixelRatio || 1, isMobile ? 1 : 2);
    canvas.width  = window.innerWidth  * dpr;
    canvas.height = window.innerHeight * dpr;
    canvas.style.width  = '100%';
    canvas.style.height = '100%';
  };
  resize();
  window.addEventListener('resize', resize);

  function getProgress() {
    const rect = heroSection.getBoundingClientRect();
    const total = heroSection.offsetHeight - window.innerHeight;
    if (total <= 0) return 0;
    return Math.min(1, Math.max(0, -rect.top / total));
  }

  /* Pre-render glow sprite RAZ — zamiast createRadialGradient na każdą cząstkę co klatkę */
  const SPRITE_R = 64;
  const sprite = document.createElement('canvas');
  sprite.width = sprite.height = SPRITE_R * 2;
  const sctx = sprite.getContext('2d');
  const sgrd = sctx.createRadialGradient(SPRITE_R, SPRITE_R, 0, SPRITE_R, SPRITE_R, SPRITE_R);
  sgrd.addColorStop(0,    'hsla(200, 100%, 92%, 0.95)');
  sgrd.addColorStop(0.4,  'hsla(210, 90%, 70%, 0.40)');
  sgrd.addColorStop(1,    'hsla(222, 60%, 35%, 0)');
  sctx.fillStyle = sgrd;
  sctx.fillRect(0, 0, SPRITE_R * 2, SPRITE_R * 2);

  /* Reusable buckets — alokowane raz, czyszczone per klatkę zamiast tworzone od nowa */
  const lineBuckets = [[], [], []];
  const lineAlpha   = [0.34, 0.20, 0.08];
  const ptsCache    = new Array(particles.length);
  for (let i = 0; i < particles.length; i++) ptsCache[i] = { x: 0, y: 0, size: 0 };

  function draw(progress) {
    const W = canvas.width, H = canvas.height;
    const cx0 = W / 2, cy0 = H / 2;
    const t = progress;

    /* Background gradient */
    const grdAngle = t * Math.PI * 2;
    const gx = cx0 + Math.cos(grdAngle) * W * 0.15;
    const gy = cy0 + Math.sin(grdAngle) * H * 0.12;
    const bg = ctx.createRadialGradient(gx, gy, 0, cx0, cy0, Math.max(W, H) * 0.75);
    const warm = Math.sin(t * Math.PI);
    bg.addColorStop(0,    `hsla(210, 75%, ${18 + warm * 28}%, 1)`);
    bg.addColorStop(0.45, `hsla(222, 60%, ${8 + warm * 14}%, 1)`);
    bg.addColorStop(1,    `hsla(222, 42%, 5%, 1)`);
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    /* Particle positions — wpisuj do cache zamiast .map() (zero alokacji) */
    const minWH = Math.min(W, H);
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const r = p.radius0 * minWH * (0.42 + 0.18 * Math.sin(t * Math.PI * 2 + p.phase));
      const a = p.angle0 + t * p.speed * Math.PI * 2;
      const o = ptsCache[i];
      o.x = cx0 + Math.cos(a) * r;
      o.y = cy0 + Math.sin(a) * r * 0.78;
      o.size = p.size * dpr;
    }

    /* Lines — batch w 3 grupach alfa, zamiast stroke per linia */
    const maxDist = minWH * 0.13;
    const maxDistSq = maxDist * maxDist;
    lineBuckets[0].length = 0; lineBuckets[1].length = 0; lineBuckets[2].length = 0;
    for (let i = 0; i < ptsCache.length; i++) {
      const a = ptsCache[i];
      for (let j = i + 1; j < ptsCache.length; j++) {
        const b = ptsCache[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dSq = dx * dx + dy * dy;
        if (dSq < maxDistSq) {
          const norm = 1 - Math.sqrt(dSq) / maxDist;
          const k = norm > 0.66 ? 0 : norm > 0.33 ? 1 : 2;
          const arr = lineBuckets[k];
          arr.push(a.x, a.y, b.x, b.y);
        }
      }
    }
    ctx.lineWidth = 1 * dpr;
    for (let k = 0; k < 3; k++) {
      const arr = lineBuckets[k];
      if (!arr.length) continue;
      ctx.strokeStyle = `hsla(210, 60%, 85%, ${lineAlpha[k]})`;
      ctx.beginPath();
      for (let m = 0, mlen = arr.length; m < mlen; m += 4) {
        ctx.moveTo(arr[m],     arr[m + 1]);
        ctx.lineTo(arr[m + 2], arr[m + 3]);
      }
      ctx.stroke();
    }

    /* Glows — drawImage sprite zamiast createRadialGradient (5-10× szybsze) */
    for (let i = 0; i < ptsCache.length; i++) {
      const p = ptsCache[i];
      const r = p.size * 6;
      ctx.drawImage(sprite, p.x - r, p.y - r, r * 2, r * 2);
    }

    /* Solid cores — jeden fill na wszystkie cząstki, zamiast osobny per cząstka */
    ctx.fillStyle = 'hsla(200, 90%, 96%, 0.9)';
    ctx.beginPath();
    for (let i = 0; i < ptsCache.length; i++) {
      const p = ptsCache[i];
      ctx.moveTo(p.x + p.size, p.y);
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
    }
    ctx.fill();
  }

  /* Smooth scrub — currentProgress goni targetProgress, dzięki czemu nawet
     szarpany scroll daje aksamitnie płynną animację (lerp smoothing). */
  let raf = 0;
  let visible = true;
  let curr = getProgress();
  let target = curr;
  let idleFrames = 0;

  const tick = () => {
    if (!visible) { raf = 0; return; }
    target = getProgress();
    const diff = target - curr;
    curr += diff * 0.18;
    if (Math.abs(diff) < 0.0005) curr = target;
    draw(curr);
    /* Inteligentne pause-on-idle: jeśli scroll stoi i lerp dotarł — przestaw rAF, oszczędność CPU. */
    if (Math.abs(diff) < 0.0002) {
      idleFrames++;
      if (idleFrames > 30) { raf = 0; return; }
    } else {
      idleFrames = 0;
    }
    raf = requestAnimationFrame(tick);
  };

  const wakeUp = () => {
    idleFrames = 0;
    if (!raf && visible && !prefersReduced) raf = requestAnimationFrame(tick);
  };

  if (prefersReduced) {
    draw(0.5);
  } else if (isMobile) {
    /* Mobile: rAF-throttled draw przy scrollu (synchronizowane z refresh rate, brak janku).
       Bez stałej pętli w tle — zero CPU draina kiedy stronie się nie scrolluje. */
    draw(getProgress());
    curr = getProgress();
    let pending = false;
    const onScroll = () => {
      if (pending) return;
      pending = true;
      requestAnimationFrame(() => {
        if (visible) draw(getProgress());
        pending = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { resize(); draw(getProgress()); });
  } else {
    /* Desktop: ciągła pętla z lerp + auto-pause przy idle. Wybudza się przy scrollu. */
    raf = requestAnimationFrame(tick);
    window.addEventListener('scroll', wakeUp, { passive: true });
  }

  const visIO = new IntersectionObserver(([entry]) => {
    visible = entry.isIntersecting;
    if (!isMobile && !prefersReduced) {
      if (visible) wakeUp();
      else if (raf) { cancelAnimationFrame(raf); raf = 0; }
    }
  }, { threshold: 0 });
  visIO.observe(heroSection);
})();

