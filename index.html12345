</section>

<!-- ============== KALKULATOR ROI ============== -->
<section id="kalkulator" class="relative py-28 md:py-36" style="border-top: 1px solid hsl(var(--border) / 0.18);">
  <div class="max-w-[var(--max)] mx-auto px-[var(--gutter)]">
    <div class="flex flex-col items-start gap-5 mb-12">
      <span class="liquid-glass rounded-full px-4 py-1.5 text-xs text-white/80">Kalkulator ROI</span>
      <h2 class="blur-text font-display uppercase font-semibold tracking-tight text-white" style="font-size: clamp(40px, 6vw, 80px); line-height: 0.92; max-width: 18ch;">
        Ile zarobisz na chatbocie.
      </h2>
      <p class="fade-up font-body text-base md:text-lg text-white/65 max-w-xl">
        Przesuń suwaki i sprawdź realny zwrot z inwestycji dla swojej firmy.
      </p>
    </div>

    <div class="liquid-glass rounded-3xl overflow-hidden grid md:grid-cols-2 gap-0 fade-up">
      <!-- LEFT: Inputs -->
      <div class="p-8 md:p-10 border-b md:border-b-0 md:border-r border-white/5">
        <div class="mb-7">
          <label class="form-label">Branża</label>
          <select class="glass-select" id="cB" onchange="calcROI()">
            <option value="2.5">Stomatologia / Klinika stomatologiczna</option>
            <option value="3">Szkoła jazdy / Auto-szkoła</option>
            <option value="2">Gabinet kosmetyczny / SPA / Uroda</option>
            <option value="2.2">Fizjoterapia / Rehabilitacja</option>
            <option value="2">Gabinet psychologiczny / Coaching</option>
            <option value="2.5">Klinika medycyny estetycznej</option>
            <option value="1.8">Restauracja / Kawiarnia / Bar</option>
            <option value="4">Usługi B2B / Doradztwo</option>
            <option value="2.2">Nieruchomości / Biuro nieruchomości</option>
            <option value="2">Sklep / E-commerce</option>
            <option value="2.3">Fitness / Siłownia / Joga</option>
            <option value="3.5">Kancelaria prawna / Rachunkowa</option>
            <option value="2">Inne usługi lokalne</option>
          </select>
        </div>

        <div class="mb-6">
          <div class="flex items-baseline justify-between mb-2">
            <span class="form-label" style="margin:0;">Odwiedziny strony / mies.</span>
            <span class="font-italic text-2xl text-white" id="vV">500</span>
          </div>
          <input type="range" class="slider" id="sV" min="100" max="5000" step="50" value="500" oninput="updSlider('sV','vV',function(v){return v.toLocaleString('pl-PL')});calcROI()">
        </div>

        <div class="mb-6">
          <div class="flex items-baseline justify-between mb-2">
            <span class="form-label" style="margin:0;">Aktualna konwersja (%)</span>
            <span class="font-italic text-2xl text-white" id="vC">1,0%</span>
          </div>
          <input type="range" class="slider" id="sC" min="0.1" max="10" step="0.1" value="1" oninput="updSlider('sC','vC',function(v){return v.toFixed(1).replace('.',',')+'%'});calcROI()">
        </div>

        <div class="mb-6">
          <div class="flex items-baseline justify-between mb-2">
            <span class="form-label" style="margin:0;">Wartość klienta (zł)</span>
            <span class="font-italic text-2xl text-white" id="vVal">400 zł</span>
          </div>
          <input type="range" class="slider" id="sVal" min="50" max="5000" step="50" value="400" oninput="updSlider('sVal','vVal',function(v){return v.toLocaleString('pl-PL')+' zł'});calcROI()">
        </div>

        <div class="mb-2">
          <div class="flex items-baseline justify-between mb-2">
            <span class="form-label" style="margin:0;">Pakiet PolAI (zł/mies.)</span>
            <span class="font-italic text-2xl text-white" id="vPkg">899 zł</span>
          </div>
          <input type="range" class="slider" id="sPkg" min="599" max="1499" step="300" value="899" oninput="updSlider('sPkg','vPkg',function(v){return v.toLocaleString('pl-PL')+' zł'});calcROI()">
        </div>
      </div>

      <!-- RIGHT: Results -->
      <div class="p-8 md:p-10 flex flex-col" style="background: rgba(0,0,0,0.4);">
        <div class="font-italic text-lg text-white/55 mb-6">Twój szacowany wynik</div>
        <div class="flex flex-col gap-3">
          <div class="calc-result-row"><span class="calc-result-lbl">Dodatkowe leady / mies.</span><span class="calc-result-val" id="crL">—</span></div>
          <div class="calc-result-row"><span class="calc-result-lbl">Dodatkowy przychód / mies.</span><span class="calc-result-val" id="crR">—</span></div>
          <div class="calc-result-row"><span class="calc-result-lbl">Zysk po odjęciu subskrypcji</span><span class="calc-result-val" id="crProfit">—</span></div>
          <div class="calc-result-row"><span class="calc-result-lbl">Zwrot z inwestycji (ROI)</span><span class="calc-result-val" id="crROI">—</span></div>
          <div class="calc-result-row"><span class="calc-result-lbl">Zwrot kosztów chatbota</span><span class="calc-result-val" id="crPB">—</span></div>
        </div>
        <div class="mt-7 text-center">
          <a href="#kontakt" class="btn btn-hero">Chcę taki wynik <i data-lucide="arrow-right"></i></a>
          <p class="text-[11px] text-white/35 mt-3">Szacunki oparte na średnich wynikach klientów PolAI.</p>
        </div>
      </div>
    </div>
  </div>
</section>

