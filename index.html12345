/* =================== KALKULATOR ROI =================== */
function updSlider(sid, vid, fmt) {
  document.getElementById(vid).textContent = fmt(parseFloat(document.getElementById(sid).value));
}
function calcROI() {
  const v   = parseFloat(document.getElementById('sV').value)   || 0;
  const c   = parseFloat(document.getElementById('sC').value)   || 0;
  const val = parseFloat(document.getElementById('sVal').value) || 0;
  const mult= parseFloat(document.getElementById('cB').value)   || 2;
  const pkg = parseFloat(document.getElementById('sPkg').value) || 899;
  const curL = v * (c / 100);
  const newC = Math.min(c * mult, 100);
  const newL = v * (newC / 100);
  const addL = Math.max(0, Math.round(newL - curL));
  const addR = Math.round(addL * val);
  const profit = addR - pkg;
  const roi = pkg > 0 ? Math.round((addR - pkg) / pkg * 100) : 0;
  const pb = addR > 0 ? Math.ceil(pkg / addR * 30) : 0;
  document.getElementById('crL').textContent = '+' + addL;
  document.getElementById('crR').textContent = '+' + addR.toLocaleString('pl-PL') + ' zł';
  document.getElementById('crProfit').textContent = (profit >= 0 ? '+' : '') + profit.toLocaleString('pl-PL') + ' zł';
  document.getElementById('crProfit').style.color = profit >= 0 ? 'hsl(var(--primary))' : '#F87171';
  document.getElementById('crROI').textContent = (roi > 0 ? '+' : '') + roi + '%';
  document.getElementById('crROI').style.color = roi >= 0 ? 'hsl(var(--primary))' : '#F87171';
  document.getElementById('crPB').textContent = pb > 0 ? pb + ' dni' : '<1 dzień';
}
calcROI();

