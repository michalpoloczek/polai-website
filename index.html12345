<button class="cbb" id="cbb" aria-label="Otwórz chatbota">
  <span class="cbnotif" id="cbnotif" style="display:none;">1</span>
  <svg class="cbci" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
