        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-[10px] font-bold tracking-[0.18em] uppercase px-4 py-1.5 rounded-full" style="background: hsl(var(--primary)); color: hsl(var(--primary-foreground));">Najpopularniejszy</div>
